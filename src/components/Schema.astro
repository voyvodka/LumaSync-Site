---
// Emits one or more schema.org JSON-LD blocks. Accepts an array so pages
// can stack Organization + WebSite + page-specific schemas without
// collapsing into an @graph wrapper (cleaner for validators).
//
// Escaping is required because schema fields (like title/description)
// could contain HTML entities. Without escaping `<` and `>`,
// an attacker could breakout of the script tag (e.g. </script>).
interface Props {
  schemas: unknown[];
}

const { schemas } = Astro.props;
---

{
  schemas.map((schema) => (
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(schema)
        .replace(/</g, '\\u003c')
        .replace(/>/g, '\\u003e')
        .replace(/&/g, '\\u0026')}
    />
  ))
}

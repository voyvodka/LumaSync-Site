---
import { getEntry, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const entry = await getEntry('legal', 'privacy');
if (!entry) {
  throw new Error('Missing legal/privacy.mdx');
}
const { Content } = await render(entry);
---

<BaseLayout
  title={entry.data.title}
  description="How LumaSync handles data — short answer: it does not."
>
  <article class="legal">
    <header>
      <h1 class="page-title">{entry.data.title}</h1>
      <p class="effective">
        Effective {entry.data.effective.toISOString().slice(0, 10)}
      </p>
    </header>
    <div class="prose">
      <Content />
    </div>
  </article>
</BaseLayout>

<style>
  .legal {
    max-width: 40rem;
    margin: 0 auto;
    padding: 4rem 1.25rem 6rem;
  }

  h1 {
    font-size: var(--fs-3xl);
    margin: 0 0 0.5rem;
    color: var(--text-primary);
  }

  .effective {
    color: var(--text-muted);
    font-family: var(--font-mono);
    font-size: 0.85rem;
    margin: 0 0 2rem;
  }

  .prose :global(p) {
    line-height: 1.65;
    color: var(--text-secondary);
  }

  .prose :global(code) {
    background: var(--surface-2);
    padding: 0.125rem 0.375rem;
    border-radius: var(--radius-sm);
    font-size: 0.9em;
  }
</style>

---
import BaseLayout from '../layouts/BaseLayout.astro';

const year = new Date().getFullYear();
const repo = 'https://github.com/voyvodka/LumaSync';

// Major bundled runtime dependencies and their licenses. Updated when
// the app's package.json changes; not auto-generated to keep the noise
// level manageable. Source of truth for each license: the package's
// own npm metadata.
const runtimeDeps = [
  { name: 'Tauri 2', license: 'MIT / Apache-2.0' },
  { name: 'React 19', license: 'MIT' },
  { name: 'Vite', license: 'MIT' },
  { name: 'Tailwind CSS 4', license: 'MIT' },
  { name: 'IBM Plex Sans / Mono', license: 'SIL Open Font License 1.1' },
  { name: 'i18next', license: 'MIT' },
];
---

<BaseLayout
  title="License"
  description="LumaSync is released under the MIT License. Site content under CC BY 4.0 unless noted."
>
  <article class="legal">
    <header>
      <p class="eyebrow">Legal</p>
      <h1 class="page-title">License</h1>
      <p class="lede">
        LumaSync is open source and free to use, modify, and redistribute under the terms below.
      </p>
    </header>

    <section>
      <h2>MIT License — code</h2>
      <p class="meta">
        Applies to the application code at
        <a href={repo}><code>voyvodka/LumaSync</code></a>
        and to the site code at
        <a href={`${repo}-site`}><code>voyvodka/lumasync-site</code></a>.
      </p>
      <pre
        class="mit">Copyright (c) {year} voyvodka

Permission is hereby granted, free of charge, to any person obtaining a copy
of this software and associated documentation files (the "Software"), to deal
in the Software without restriction, including without limitation the rights
to use, copy, modify, merge, publish, distribute, sublicense, and/or sell
copies of the Software, and to permit persons to whom the Software is
furnished to do so, subject to the following conditions:

The above copyright notice and this permission notice shall be included in all
copies or substantial portions of the Software.

THE SOFTWARE IS PROVIDED "AS IS", WITHOUT WARRANTY OF ANY KIND, EXPRESS OR
IMPLIED, INCLUDING BUT NOT LIMITED TO THE WARRANTIES OF MERCHANTABILITY,
FITNESS FOR A PARTICULAR PURPOSE AND NONINFRINGEMENT. IN NO EVENT SHALL THE
AUTHORS OR COPYRIGHT HOLDERS BE LIABLE FOR ANY CLAIM, DAMAGES OR OTHER
LIABILITY, WHETHER IN AN ACTION OF CONTRACT, TORT OR OTHERWISE, ARISING FROM,
OUT OF OR IN CONNECTION WITH THE SOFTWARE OR THE USE OR OTHER DEALINGS IN THE
SOFTWARE.</pre>
    </section>

    <section>
      <h2>CC BY 4.0 — site content</h2>
      <p>
        Copy, docs, comparison pages, and blog posts on
        <code>lumasync.app</code> are licensed under the
        <a href="https://creativecommons.org/licenses/by/4.0/"
          >Creative Commons Attribution 4.0 International License</a
        >. In practice: you can copy, translate, and build on the content — just credit LumaSync
        with a link back.
      </p>
      <p>Per-file exceptions (if any) are noted at the top of the file.</p>
    </section>

    <section>
      <h2>Third-party components</h2>
      <p>
        The app bundles a number of open-source dependencies. Major runtime components and their
        licenses:
      </p>
      <ul>
        {
          runtimeDeps.map((dep) => (
            <li>
              <strong>{dep.name}</strong> — <span class="muted">{dep.license}</span>
            </li>
          ))
        }
      </ul>
      <p class="meta">
        A complete dependency manifest is in the app's
        <a href={`${repo}/blob/main/package.json`}><code>package.json</code></a>
        and
        <a href={`${repo}/blob/main/src-tauri/Cargo.toml`}><code>Cargo.toml</code></a>. Each package
        ships its own license file under
        <code>node_modules/&lt;package&gt;/LICENSE</code> or the Cargo equivalent.
      </p>
    </section>

    <section>
      <h2>Trademarks</h2>
      <p>
        <strong>LumaSync</strong> and the brand mark are project identifiers. No trademark is registered.
        You may refer to the project by name in reviews, comparisons, and documentation. Please don't
        imply endorsement or official affiliation.
        <strong>Philips Hue</strong> and <strong>Hue Sync</strong> are trademarks of Signify — referenced
        here only for interoperability and comparison.
      </p>
    </section>
  </article>
</BaseLayout>

<style>
  .legal {
    max-width: calc(var(--container-content) + 2.5rem);
    margin-inline: auto;
    padding: 3rem 1.25rem 5rem;
  }

  header {
    margin-bottom: 2.5rem;
  }

  h1 {
    font-size: var(--fs-3xl);
    margin: 0 0 0.75rem;
    color: var(--text-primary);
  }

  .lede {
    color: var(--text-secondary);
    font-size: var(--fs-lg);
    line-height: var(--lh-relaxed);
    margin: 0;
    max-width: 36rem;
  }

  section {
    margin-top: 2.5rem;
  }

  h2 {
    font-size: var(--fs-xl);
    color: var(--text-primary);
    margin: 0 0 0.75rem;
  }

  p {
    margin: 0 0 0.75rem;
    color: var(--text-secondary);
    line-height: var(--lh-relaxed);
  }

  .meta {
    color: var(--text-muted);
    font-size: var(--fs-sm);
  }

  a {
    color: var(--text-primary);
    text-decoration: underline;
    text-decoration-color: var(--border-strong);
    text-underline-offset: 3px;
  }

  a:hover {
    text-decoration-color: var(--accent);
  }

  code {
    background: var(--surface-2);
    padding: 0.125rem 0.375rem;
    border-radius: var(--radius-sm);
    font-size: 0.9em;
    color: var(--text-primary);
  }

  .mit {
    white-space: pre-wrap;
    background: var(--surface-1);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    color: var(--text-secondary);
    font-size: 0.9rem;
    line-height: 1.6;
    margin: 0;
  }

  ul {
    list-style: none;
    margin: 0 0 1rem;
    padding: 0;
    display: grid;
    gap: 0.375rem;
  }

  ul li {
    padding-left: 1rem;
    position: relative;
    color: var(--text-secondary);
    font-size: var(--fs-sm);
  }

  ul li::before {
    content: '·';
    position: absolute;
    left: 0;
    color: var(--accent);
  }

  ul li strong {
    color: var(--text-primary);
    font-weight: 500;
  }

  .muted {
    color: var(--text-muted);
  }
</style>

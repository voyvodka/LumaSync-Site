---
interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  noindex?: boolean;
}

const { title, description, canonical, ogImage, noindex } = Astro.props;

const siteTitle = title === 'LumaSync' ? title : `${title} · LumaSync`;
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, Astro.site).toString();

// Derive the OG path from the current URL. Matches the keys in
// src/pages/og/[...route].ts — root becomes "landing", trailing
// slashes are stripped. Pages can override via the ogImage prop
// (used for 404 / future hand-crafted hero).
function derivedOgPath(pathname: string): string {
  const trimmed = pathname.replace(/\/$/, '').replace(/^\//, '');
  if (!trimmed) return '/og/landing.png';
  return `/og/${trimmed}.png`;
}

const ogImageUrl = ogImage
  ? new URL(ogImage, Astro.site).toString()
  : new URL(derivedOgPath(Astro.url.pathname), Astro.site).toString();
---

<title>{siteTitle}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalUrl} />
{noindex && <meta name="robots" content="noindex,nofollow" />}

<meta property="og:type" content="website" />
<meta property="og:title" content={siteTitle} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:image" content={ogImageUrl} />
<meta property="og:site_name" content="LumaSync" />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={siteTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageUrl} />

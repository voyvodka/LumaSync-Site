---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'LumaSync';
const description =
  'LumaSync drives WS2812B LED strips over USB and Philips Hue Entertainment areas from the same tray-first desktop app, at the same time, from one screen source. Open source. No cloud. No HDMI box.';

const repo = 'https://github.com/voyvodka/LumaSync';
---

<BaseLayout title={title} description={description}>
  {/* ─── Hero ───────────────────────────────────────────────── */}
  <section class="hero">
    <div class="hero-inner">
      <p class="eyebrow">Open source · Tauri 2 · MIT</p>
      <h1 class="display">Your screen, your lights. Locally.</h1>
      <p class="subhead">{description}</p>
      <div class="cta-row">
        <a class="cta-primary" href="/download" data-os-cta> Download </a>
        <a class="cta-secondary" href={repo}> View on GitHub → </a>
      </div>
      <p class="platform-note">macOS · Windows · Linux (experimental)</p>
    </div>

    <figure class="hero-visual">
      {
        /*
         Static recreation of LumaSync's Lights section in full mode
         (900×620). Uses the app's Rev 07 amber palette tokens
         (--lm-*), IBM Plex Mono for chrome text, and element shapes
         that mirror the real titlebar + sidebar + scene grid + edge
         preview + status bar. Not interactive — decorative only —
         so aria-hidden plus a descriptive caption keep screen
         readers on the real story.
       */
      }
      <div
        class="app-mock"
        role="img"
        aria-label="LumaSync full-mode Lights section — Ambilight running, scene presets visible, edge-signal preview and Δ/Σ telemetry pill live."
      >
        <div class="app-chrome">
          <div class="app-chrome-brand">
            <span class="mono-mark" aria-hidden="true"></span>
            <span>LUMA<b>SYNC</b></span>
          </div>
          <ul class="app-chrome-tabs" role="list">
            <li>Ambient</li>
            <li class="is-on">Lights</li>
            <li>Room map</li>
            <li>Settings</li>
          </ul>
          <span class="app-chrome-ver" aria-hidden="true">v1.3.1</span>
        </div>

        <div class="app-body">
          <aside class="app-side">
            <p class="app-kicker">Mode</p>
            <div class="app-mode">
              <button type="button" class="app-mode-tile">Off</button>
              <button type="button" class="app-mode-tile is-on">
                <span class="dot" aria-hidden="true"></span> Ambilight
              </button>
              <button type="button" class="app-mode-tile">Solid</button>
            </div>

            <p class="app-kicker">Devices</p>
            <ul class="app-devices" role="list">
              <li><span class="pip pip-ok" aria-hidden="true"></span> USB · CH340</li>
              <li><span class="pip pip-ok" aria-hidden="true"></span> Hue · Living</li>
            </ul>
          </aside>

          <section class="app-main">
            <p class="app-kicker">Scene presets</p>
            <ul class="app-scenes" role="list">
              <li style="--s:#D9521E">Movie</li>
              <li style="--s:#66B4FF">Game</li>
              <li style="--s:#FF6A88">Music</li>
              <li style="--s:#FFC860">Chill</li>
              <li style="--s:#4CAD70">Read</li>
            </ul>

            <div class="app-saturation">
              <p class="app-kicker">Saturation</p>
              <div class="slider" role="presentation">
                <span class="slider-track"></span>
                <span class="slider-fill" style="width: 60%"></span>
                <span class="slider-thumb" style="left: 60%"></span>
              </div>
              <span class="slider-val">120%</span>
            </div>

            <div class="app-edge" aria-hidden="true">
              <p class="app-kicker">Edge signal</p>
              <div class="edge-frame">
                <span class="edge edge-top"></span>
                <span class="edge edge-right"></span>
                <span class="edge edge-bottom"></span>
                <span class="edge edge-left"></span>
                <span class="edge-screen"></span>
              </div>
            </div>
          </section>
        </div>

        <div class="app-status">
          <span class="app-status-pair"
            ><span class="k">mode</span><span class="v">
              <span class="pip pip-ok" aria-hidden="true"></span> ambilight</span
            ></span
          >
          <span class="app-status-pair"
            ><span class="k">usb</span><span class="v">
              <span class="pip pip-ok" aria-hidden="true"></span> ch340</span
            ></span
          >
          <span class="app-status-pair"
            ><span class="k">hue</span><span class="v">
              <span class="pip pip-ok" aria-hidden="true"></span> stream</span
            ></span
          >
          <span class="app-status-tele" aria-hidden="true">
            <b>Δ</b> 12 ms <span class="tele-sep"></span>
            <b>Σ</b> 60 fps
          </span>
        </div>
      </div>
      <figcaption>
        Full-mode Lights section with Ambilight active — static recreation using the app's Rev 07
        amber tokens.
      </figcaption>
    </figure>
  </section>

  {/* ─── "Both, at once" feature grid ───────────────────────── */}
  <section class="features">
    <p class="section-eyebrow">Both, at once</p>
    <h2 class="section-title">One pipeline. Two targets.</h2>
    <div class="feature-grid">
      <article>
        <div class="feature-icon" aria-hidden="true">USB</div>
        <h3>USB LED strips</h3>
        <p>
          CH340 and FT232 controllers at 115200 baud, running the
          <a href="/docs/usb-leds/serial-protocol">LumaSync v1 serial frame</a>. Opt-in Adalight
          profile on the v1.4 roadmap.
        </p>
        <a href="/docs/usb-leds/controllers">Supported chipsets →</a>
      </article>

      <article>
        <div class="feature-icon" aria-hidden="true">HUE</div>
        <h3>Philips Hue Entertainment</h3>
        <p>
          DTLS 1.2 PSK streaming to any configured Entertainment Area. Up to 20 Hz — the bridge's
          real limit.
        </p>
        <a href="/docs/hue/entertainment-area">How Hue streaming works →</a>
      </article>

      <article>
        <div class="feature-icon" aria-hidden="true">⌃</div>
        <h3>Both, synchronized</h3>
        <p>
          Same screen source drives both targets. Pick per mode: USB, Hue, or both — switched from
          the tray.
        </p>
        <ul class="feature-badges" role="list" aria-label="Ships today">
          <li>Live Δ/Σ telemetry</li>
          <li>EN · TR i18n</li>
          <li>Compact 320×480 / Full 900×620</li>
        </ul>
        <a href="/docs/getting-started/first-setup">First-setup walkthrough →</a>
      </article>
    </div>
  </section>

  {/* ─── Ambient mode preview ──────────────────────────────── */}
  <section class="callout">
    <div class="callout-copy">
      <p class="section-eyebrow">Ambient mode</p>
      <h2 class="section-title">Real-time screen capture. 20 Hz update.</h2>
      <p class="callout-body">
        Tuned for latency, not flash. The telemetry pill shows live capture and send rates so you
        can see when the pipeline is healthy and when it isn't — no mystery numbers.
      </p>
      <a class="inline-cta" href="/docs/ambilight/performance">Read about performance →</a>
    </div>
    <figure class="callout-visual">
      {/* Inlined to skip an HTTP round-trip; id attrs are prefixed per-figure. */}
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 1400 900"
        width="1400"
        height="900"
        role="img"
        aria-label="LumaSync ambient mode with the edge-signal preview and live telemetry overlay."
      >
        <defs>
          <linearGradient id="ambient-surface" x1="0%" y1="0%" x2="100%" y2="100%">
            <stop offset="0%" stop-color="#0f1114"></stop>
            <stop offset="100%" stop-color="#1e2229"></stop>
          </linearGradient>
          <radialGradient id="ambient-glow" cx="30%" cy="25%" r="70%">
            <stop offset="0%" stop-color="#ffb020" stop-opacity="0.18"></stop>
            <stop offset="70%" stop-color="#ffb020" stop-opacity="0"></stop>
          </radialGradient>
        </defs>
        <rect width="1400" height="900" fill="url(#ambient-surface)"></rect>
        <rect width="1400" height="900" fill="url(#ambient-glow)"></rect>
        <rect x="0" y="0" width="12" height="900" fill="#ffb020"></rect>
        <g transform="translate(700, 450)">
          <rect
            x="-210"
            y="-24"
            width="420"
            height="48"
            rx="24"
            fill="rgba(10,11,14,0.65)"
            stroke="rgba(231,236,242,0.16)"
            stroke-width="1"></rect>
          <circle cx="-180" cy="0" r="4" fill="#ffb020"></circle>
          <text
            x="0"
            y="5"
            font-family="IBM Plex Mono, ui-monospace, monospace"
            font-size="16"
            letter-spacing="1.2"
            fill="#a8b0bc"
            text-anchor="middle">ambient-mode-preview · 1400 × 900</text
          >
        </g>
      </svg>
      <div class="telemetry-pill" aria-hidden="true">
        <span class="pill-eyebrow">Live</span>
        <span><strong>Δ</strong> 12 ms</span>
        <span class="pill-sep"></span>
        <span><strong>Σ</strong> 60 fps</span>
      </div>
    </figure>
  </section>

  {/* ─── Room map editor ───────────────────────────────────── */}
  <section class="callout reverse">
    <figure class="callout-visual">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 1400 900"
        width="1400"
        height="900"
        role="img"
        aria-label="LumaSync's room map editor canvas with a TV anchor, furniture objects, a USB strip, and Hue channel overlays."
      >
        <defs>
          <linearGradient id="room-surface" x1="0%" y1="0%" x2="100%" y2="100%">
            <stop offset="0%" stop-color="#0f1114"></stop>
            <stop offset="100%" stop-color="#1e2229"></stop>
          </linearGradient>
          <radialGradient id="room-glow" cx="70%" cy="30%" r="70%">
            <stop offset="0%" stop-color="#ffb020" stop-opacity="0.14"></stop>
            <stop offset="70%" stop-color="#ffb020" stop-opacity="0"></stop>
          </radialGradient>
        </defs>
        <rect width="1400" height="900" fill="url(#room-surface)"></rect>
        <rect width="1400" height="900" fill="url(#room-glow)"></rect>
        <rect x="0" y="0" width="12" height="900" fill="#ffb020"></rect>
        <g opacity="0.35" stroke="rgba(231,236,242,0.14)" stroke-width="1" fill="none">
          <g>
            <line x1="120" y1="120" x2="1280" y2="120"></line>
            <line x1="120" y1="220" x2="1280" y2="220"></line>
            <line x1="120" y1="320" x2="1280" y2="320"></line>
            <line x1="120" y1="420" x2="1280" y2="420"></line>
            <line x1="120" y1="520" x2="1280" y2="520"></line>
            <line x1="120" y1="620" x2="1280" y2="620"></line>
            <line x1="120" y1="720" x2="1280" y2="720"></line>
          </g>
          <g>
            <line x1="220" y1="90" x2="220" y2="780"></line>
            <line x1="400" y1="90" x2="400" y2="780"></line>
            <line x1="580" y1="90" x2="580" y2="780"></line>
            <line x1="760" y1="90" x2="760" y2="780"></line>
            <line x1="940" y1="90" x2="940" y2="780"></line>
            <line x1="1120" y1="90" x2="1120" y2="780"></line>
          </g>
        </g>
        <g transform="translate(700, 450)">
          <rect
            x="-200"
            y="-24"
            width="400"
            height="48"
            rx="24"
            fill="rgba(10,11,14,0.75)"
            stroke="rgba(231,236,242,0.16)"
            stroke-width="1"></rect>
          <circle cx="-170" cy="0" r="4" fill="#ffb020"></circle>
          <text
            x="0"
            y="5"
            font-family="IBM Plex Mono, ui-monospace, monospace"
            font-size="16"
            letter-spacing="1.2"
            fill="#a8b0bc"
            text-anchor="middle">room-map-editor · 1400 × 900</text
          >
        </g>
      </svg>
    </figure>
    <div class="callout-copy">
      <p class="section-eyebrow">Room map editor</p>
      <h2 class="section-title">A canvas, not a config file.</h2>
      <p class="callout-body">
        Drag your TV, furniture, and USB strips onto a grid. Hue channels project onto normalized
        coordinates. Undo / redo, snap guides, keyboard shortcuts.
      </p>
      <a class="inline-cta" href="/docs/usb-leds/calibration">Calibration docs →</a>
    </div>
  </section>

  {/* ─── Tray-first UX ─────────────────────────────────────── */}
  <section class="callout">
    <div class="callout-copy">
      <p class="section-eyebrow">Tray-first</p>
      <h2 class="section-title">Lives where it belongs — out of your way.</h2>
      <p class="callout-body">
        Single window hides to tray on close. Compact 320×480 mode for quick toggles, full 900×620
        mode when you want to configure. Auto-starts on login, if you want it to.
      </p>
      <a class="inline-cta" href="/docs/getting-started/first-setup">First-setup walkthrough →</a>
    </div>
    <figure class="callout-visual dual">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 320 480"
        width="320"
        height="480"
        role="img"
        aria-label="LumaSync compact mode — 320 × 480 window with mode tiles and scene picker."
        class="dual-compact"
      >
        <defs>
          <linearGradient id="compact-surface" x1="0%" y1="0%" x2="0%" y2="100%">
            <stop offset="0%" stop-color="#0f1114"></stop>
            <stop offset="100%" stop-color="#1e2229"></stop>
          </linearGradient>
          <radialGradient id="compact-glow" cx="50%" cy="15%" r="80%">
            <stop offset="0%" stop-color="#ffb020" stop-opacity="0.14"></stop>
            <stop offset="70%" stop-color="#ffb020" stop-opacity="0"></stop>
          </radialGradient>
        </defs>
        <rect width="320" height="480" fill="url(#compact-surface)"></rect>
        <rect width="320" height="480" fill="url(#compact-glow)"></rect>
        <rect x="0" y="0" width="6" height="480" fill="#ffb020"></rect>
        <g transform="translate(160, 240)">
          <rect
            x="-120"
            y="-20"
            width="240"
            height="40"
            rx="20"
            fill="rgba(10,11,14,0.65)"
            stroke="rgba(231,236,242,0.16)"
            stroke-width="1"></rect>
          <circle cx="-98" cy="0" r="3" fill="#ffb020"></circle>
          <text
            x="0"
            y="4"
            font-family="IBM Plex Mono, ui-monospace, monospace"
            font-size="11"
            letter-spacing="1"
            fill="#a8b0bc"
            text-anchor="middle">compact-mode · 320 × 480</text
          >
        </g>
      </svg>
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 900 620"
        width="900"
        height="620"
        role="img"
        aria-label="LumaSync full mode — main window with sidebar and Lights section open."
        class="dual-full"
      >
        <defs>
          <linearGradient id="full-surface" x1="0%" y1="0%" x2="100%" y2="100%">
            <stop offset="0%" stop-color="#0f1114"></stop>
            <stop offset="100%" stop-color="#1e2229"></stop>
          </linearGradient>
          <radialGradient id="full-glow" cx="30%" cy="25%" r="70%">
            <stop offset="0%" stop-color="#ffb020" stop-opacity="0.18"></stop>
            <stop offset="70%" stop-color="#ffb020" stop-opacity="0"></stop>
          </radialGradient>
        </defs>
        <rect width="900" height="620" fill="url(#full-surface)"></rect>
        <rect width="900" height="620" fill="url(#full-glow)"></rect>
        <rect x="0" y="0" width="10" height="620" fill="#ffb020"></rect>
        <g transform="translate(450, 310)">
          <rect
            x="-150"
            y="-22"
            width="300"
            height="44"
            rx="22"
            fill="rgba(10,11,14,0.65)"
            stroke="rgba(231,236,242,0.16)"
            stroke-width="1"></rect>
          <circle cx="-125" cy="0" r="4" fill="#ffb020"></circle>
          <text
            x="0"
            y="5"
            font-family="IBM Plex Mono, ui-monospace, monospace"
            font-size="14"
            letter-spacing="1.2"
            fill="#a8b0bc"
            text-anchor="middle">full-mode · 900 × 620</text
          >
        </g>
      </svg>
    </figure>
  </section>

  {/* ─── Platform support ──────────────────────────────────── */}
  <section class="platforms">
    <p class="section-eyebrow">Platform support</p>
    <h2 class="section-title">Installs anywhere you already work.</h2>
    <div class="platform-grid">
      <article>
        <h3>
          macOS
          <span class="tag tag-ok">Full support</span>
        </h3>
        <p>Primary development target. Universal binary (Apple Silicon + Intel).</p>
      </article>
      <article>
        <h3>
          Windows
          <span class="tag tag-ok">Supported</span>
        </h3>
        <p>MSI installer, winget in progress. USB + Hue paths fully functional.</p>
      </article>
      <article>
        <h3>
          Linux
          <span class="tag tag-warn">Experimental</span>
        </h3>
        <p>
          AppImage ships today, Flathub submission underway. Tray behavior varies by desktop
          environment.
        </p>
      </article>
    </div>
  </section>

  {/* ─── Open, signed, auditable ───────────────────────────── */}
  <section class="trust">
    <p class="section-eyebrow">Open · signed · auditable</p>
    <h2 class="section-title">No accounts. No telemetry. No cloud.</h2>
    <div class="trust-grid">
      <div>
        <p class="trust-label">MIT licensed</p>
        <p>Source at <a href={repo}>voyvodka/LumaSync</a>. Fork it, ship it, read it.</p>
      </div>
      <div>
        <p class="trust-label">Updates signed with minisign</p>
        <p>
          Every binary is signature-verified before replacing the on-disk version. <a
            href="/docs/advanced/auto-updater">How updates work</a
          >.
        </p>
      </div>
      <div>
        <p class="trust-label">Credentials stay local</p>
        <p>
          Hue bridge pairing and everything else lives in
          <code>~/.config/lumasync/app.json</code> on your machine.
        </p>
      </div>
    </div>
  </section>

  {/* ─── Roadmap honesty ───────────────────────────────────── */}
  <section class="roadmap">
    <p class="section-eyebrow">Transparent about scope</p>
    <h2 class="section-title">Roadmap honesty.</h2>
    <p class="roadmap-lede">
      No vaporware, no silently-aging footnotes. What shipped, what's queued, and what we've
      explicitly rejected — read end-to-end.
    </p>
    <div class="roadmap-grid">
      <article class="roadmap-col roadmap-shipped">
        <header>
          <span class="roadmap-tag tag-shipped">Shipped</span>
          <h3>Current release</h3>
        </header>
        <ul role="list">
          <li>Compact 320×480 mode alongside the 900×620 full window</li>
          <li>Live edge-signal preview (top / bottom / left / right RGB gradients)</li>
          <li>Runtime Δ / Σ telemetry pill — frame latency + FPS in the status bar</li>
          <li>Luminance-preserving saturation control (50–200%)</li>
          <li>Unified scene preset catalog with a brightness field</li>
          <li>EN + TR i18n parity with an automatic 1:1 verifier</li>
        </ul>
        <a class="inline-cta" href="/changelog">Full changelog →</a>
      </article>

      <article class="roadmap-col roadmap-next">
        <header>
          <span class="roadmap-tag tag-next">Next</span>
          <h3>v1.4 — queued, not shipped</h3>
        </header>
        <ul role="list">
          <li>USB per-LED sampling (the strip runs on one pixel today)</li>
          <li>Adalight firmware profile — opt-in compatibility toggle</li>
          <li>Wired keyboard shortcuts (⌥1 / ⌥2 / ⌥3 + ⌘,)</li>
          <li>Native OS notifications via <code>tauri-plugin-notification</code></li>
          <li>Multi-monitor capture honouring user display selection</li>
        </ul>
        <p class="roadmap-caveat">
          Dates are estimates. Source of truth is the project's internal roadmap.
        </p>
      </article>

      <article class="roadmap-col roadmap-rejected">
        <header>
          <span class="roadmap-tag tag-rejected">Never</span>
          <h3>DNA-conflicts</h3>
        </header>
        <ul role="list">
          <li>Daemon / headless mode — answered via a local HTTP API + Home Assistant</li>
          <li>Cloud telemetry or Sentry-class reporting — privacy posture is load-bearing</li>
          <li>Cloud scene gallery — local files and JSON export only</li>
          <li>AI-prompt scene inference — cloud inference breaks the zero-network promise</li>
          <li>Docker / headless Linux server distribution — tray-first DNA</li>
        </ul>
        <p class="roadmap-caveat">These are rejections, not "not yet" items.</p>
      </article>
    </div>
  </section>

  {/* ─── Not for you if… ───────────────────────────────────── */}
  <section class="filter">
    <p class="section-eyebrow">Honest filter</p>
    <h2 class="section-title">Not for you if…</h2>
    <ul role="list">
      <li>
        <strong>You need HDMI passthrough for a console or Apple TV.</strong>
        LumaSync reads the OS screen buffer — no HDMI in the signal path. Grab a <a
          href="/compare/hue-sync">Hue Sync Box</a
        > instead.
      </li>
      <li>
        <strong>You don't have a Hue Bridge or a WS2812B controller.</strong>
        The app will run, but you won't see anything light up. Start with the <a
          href="/docs/getting-started/hardware-checklist">hardware checklist</a
        >.
      </li>
      <li>
        <strong>You're on an unusual Linux desktop environment.</strong>
        Tray behavior varies — GNOME needs an AppIndicator extension, tiling WMs may force windows into
        tiles. Community-driven support on Linux for now.
      </li>
    </ul>
  </section>
</BaseLayout>

<script is:inline>
  (() => {
    const btn = document.querySelector('[data-os-cta]');
    if (!btn) return;
    const ua = navigator.userAgent;
    const label = /Windows/i.test(ua)
      ? 'Download for Windows'
      : /Linux/i.test(ua) || /X11/i.test(ua)
        ? 'Download for Linux'
        : /Mac|macOS/i.test(ua)
          ? 'Download for macOS'
          : 'Download';
    btn.textContent = label;
  })();
</script>

<style>
  /* ─── Shared ────────────────────────────────────────────── */
  .hero,
  .features,
  .callout,
  .platforms,
  .trust,
  .roadmap,
  .filter {
    max-width: calc(var(--container-wide) + 2.5rem);
    margin-inline: auto;
    padding-inline: 1.25rem;
  }

  .section-eyebrow {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--accent);
    margin: 0 0 0.75rem;
  }

  .section-title {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: var(--fs-3xl);
    line-height: var(--lh-tight);
    letter-spacing: var(--tracking-tight);
    color: var(--text-primary);
    margin: 0 0 1.5rem;
    max-width: 28ch;
  }

  /* ─── Hero ────────────────────────────────────────────── */
  .hero {
    padding-block: 5rem 4rem;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.1fr);
    gap: 3rem;
    align-items: center;
  }

  .hero-inner .eyebrow {
    margin: 0 0 1.25rem;
  }

  .hero h1.display {
    font-size: var(--fs-hero);
    color: var(--text-primary);
    margin: 0 0 1.125rem;
    max-width: 16ch;
  }

  .subhead {
    color: var(--text-secondary);
    font-size: var(--fs-lg);
    line-height: var(--lh-relaxed);
    margin: 0 0 2rem;
    max-width: 34rem;
  }

  .cta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: center;
  }

  .cta-primary,
  .cta-secondary {
    display: inline-flex;
    align-items: center;
    padding: 0.75rem 1.125rem;
    border-radius: var(--radius-md);
    font-weight: 500;
    text-decoration: none;
    font-size: var(--fs-sm);
    transition:
      background-color var(--duration-fast) var(--ease-out),
      border-color var(--duration-fast) var(--ease-out);
  }

  .cta-primary {
    background: var(--accent);
    color: var(--text-inverse);
  }

  .cta-primary:hover {
    background: var(--accent-strong);
  }

  .cta-secondary {
    border: 1px solid var(--border-strong);
    background: var(--surface-1);
    color: var(--text-primary);
  }

  .cta-secondary:hover {
    background: var(--surface-2);
  }

  .platform-note {
    margin-top: 1.5rem;
    color: var(--text-muted);
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    letter-spacing: var(--tracking-wide);
  }

  .hero-visual figcaption {
    margin-top: 0.625rem;
    color: var(--text-muted);
    font-size: var(--fs-xs);
    font-family: var(--font-mono);
    letter-spacing: var(--tracking-wide);
    text-align: center;
  }

  /* ─── Placeholder / real-image visuals ────────────────── */
  .hero-visual-img,
  .callout-visual img {
    display: block;
    width: 100%;
    height: auto;
    border: 1px solid var(--border-strong);
    border-radius: var(--radius-lg);
  }

  /* ─── App mock — static recreation of the LumaSync Lights section
   *   Self-contained colour scope using Rev 07 amber tokens from the
   *   app's own styles.css (--lm-*), so the mock stays visually true
   *   even if the site palette drifts. Not interactive — all children
   *   are decorative; the wrapper's role="img" + aria-label carries
   *   the narrative for assistive tech. */
  .app-mock {
    --lm-bg: #07080a;
    --lm-panel: #0e1014;
    --lm-panel-2: #14171d;
    --lm-panel-3: #181c24;
    --lm-line: #1a1e25;
    --lm-line-2: #252b34;
    --lm-ink: #eaeef4;
    --lm-ink-dim: #8a94a3;
    --lm-ink-faint: #4d5564;
    --lm-amber: #ffb020;
    --lm-amber-soft: rgba(255, 176, 32, 0.12);
    --lm-green: #4ade80;
    --lm-mono: var(--font-mono);

    aspect-ratio: 16 / 10;
    width: 100%;
    background: var(--lm-bg);
    border: 1px solid var(--border-strong);
    border-radius: var(--radius-lg);
    overflow: hidden;
    display: grid;
    grid-template-rows: 30px 1fr 28px;
    color: var(--lm-ink);
    font-family: var(--lm-mono);
    box-shadow: var(--shadow-lift);
    container-type: inline-size;
  }

  /* Title bar */
  .app-chrome {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 0 12px;
    background: rgba(8, 9, 12, 0.9);
    border-bottom: 1px solid var(--lm-line);
    font-size: 9.5px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--lm-ink-faint);
  }

  .app-chrome-brand {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: #f1f4f9;
    font-weight: 600;
    letter-spacing: 0.22em;
  }

  .app-chrome-brand .mono-mark {
    display: inline-block;
    width: 9px;
    height: 9px;
    background: var(--lm-amber);
    clip-path: polygon(55% 0%, 100% 15%, 45% 100%, 0% 85%);
  }

  .app-chrome-brand b {
    color: var(--lm-amber);
    font-weight: 600;
  }

  .app-chrome-tabs {
    display: flex;
    gap: 0;
    list-style: none;
    margin: 0;
    padding: 0;
    height: 100%;
  }

  .app-chrome-tabs li {
    display: flex;
    align-items: center;
    padding: 0 10px;
    font-size: 8.5px;
    letter-spacing: 0.14em;
    color: var(--lm-ink-faint);
    position: relative;
  }

  .app-chrome-tabs li.is-on {
    color: var(--lm-ink);
  }

  .app-chrome-tabs li.is-on::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: -1px;
    height: 1.5px;
    background: var(--lm-amber);
    box-shadow: 0 0 8px rgba(255, 176, 32, 0.5);
  }

  .app-chrome-ver {
    margin-left: auto;
    font-size: 8.5px;
    letter-spacing: 0.12em;
    color: var(--lm-ink-faint);
  }

  /* Body: sidebar + main */
  .app-body {
    display: grid;
    grid-template-columns: 160px 1fr;
    min-height: 0;
  }

  .app-side {
    background: var(--lm-panel);
    border-right: 1px solid var(--lm-line);
    padding: 14px 12px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    font-family: var(--font-sans);
    min-width: 0;
  }

  .app-kicker {
    margin: 0;
    font-family: var(--lm-mono);
    font-size: 8.5px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--lm-ink-faint);
  }

  .app-mode {
    display: flex;
    flex-direction: column;
    gap: 5px;
  }

  .app-mode-tile {
    all: unset;
    padding: 8px 10px;
    background: var(--lm-panel-2);
    border: 1px solid var(--lm-line);
    border-radius: 6px;
    color: var(--lm-ink-dim);
    font-size: 11px;
    font-weight: 500;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    cursor: default;
  }

  .app-mode-tile.is-on {
    background: var(--lm-amber-soft);
    border-color: rgba(255, 176, 32, 0.4);
    color: var(--lm-ink);
  }

  .app-mode-tile .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--lm-amber);
    box-shadow: 0 0 6px var(--lm-amber);
  }

  .app-devices {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 5px;
    font-size: 10.5px;
    color: var(--lm-ink-dim);
  }

  .app-devices li {
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .pip {
    display: inline-block;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .pip-ok {
    background: var(--lm-green);
    box-shadow: 0 0 5px rgba(74, 222, 128, 0.6);
  }

  /* Main section */
  .app-main {
    padding: 16px 18px;
    display: grid;
    grid-template-rows: auto auto 1fr;
    gap: 14px;
    font-family: var(--font-sans);
    min-height: 0;
    min-width: 0;
  }

  .app-scenes {
    list-style: none;
    margin: 6px 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 6px;
  }

  .app-scenes li {
    position: relative;
    aspect-ratio: 1.6 / 1;
    background: var(--lm-panel-2);
    border: 1px solid var(--lm-line);
    border-radius: 8px;
    font-size: 10px;
    font-weight: 500;
    color: var(--lm-ink);
    display: flex;
    align-items: flex-end;
    padding: 7px 9px;
    overflow: hidden;
  }

  .app-scenes li::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 50% 15%, var(--s) 0%, transparent 70%);
    opacity: 0.55;
  }

  .app-saturation {
    display: grid;
    grid-template-columns: auto 1fr auto;
    grid-template-rows: auto auto;
    grid-column-gap: 12px;
    align-items: center;
  }

  .app-saturation .app-kicker {
    grid-column: 1;
    grid-row: 1 / 3;
    align-self: center;
  }

  .slider {
    grid-column: 2;
    grid-row: 1 / 3;
    position: relative;
    height: 4px;
    align-self: center;
  }

  .slider-track {
    position: absolute;
    inset: 0;
    background: var(--lm-line-2);
    border-radius: 2px;
  }

  .slider-fill {
    position: absolute;
    top: 0;
    bottom: 0;
    left: 0;
    background: var(--lm-amber);
    border-radius: 2px;
  }

  .slider-thumb {
    position: absolute;
    top: 50%;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--lm-amber);
    transform: translate(-50%, -50%);
    box-shadow: 0 0 8px rgba(255, 176, 32, 0.55);
  }

  .slider-val {
    grid-column: 3;
    grid-row: 1 / 3;
    align-self: center;
    font-family: var(--lm-mono);
    font-size: 10px;
    color: var(--lm-ink);
    letter-spacing: 0.06em;
  }

  /* Edge signal preview */
  .app-edge {
    min-height: 0;
  }

  .edge-frame {
    position: relative;
    width: 100%;
    max-width: 320px;
    margin-top: 6px;
    aspect-ratio: 16 / 10;
    background: var(--lm-panel-2);
    border: 1px solid var(--lm-line);
    border-radius: 6px;
    overflow: hidden;
  }

  .edge {
    position: absolute;
  }

  .edge-top {
    top: 0;
    left: 0;
    right: 0;
    height: 14%;
    background: linear-gradient(90deg, #d9521e 0%, #ffc860 35%, #66b4ff 65%, #4cad70 100%);
    opacity: 0.75;
  }

  .edge-bottom {
    bottom: 0;
    left: 0;
    right: 0;
    height: 14%;
    background: linear-gradient(90deg, #4cad70 0%, #66b4ff 30%, #ff6a88 65%, #d9521e 100%);
    opacity: 0.75;
  }

  .edge-left {
    top: 14%;
    bottom: 14%;
    left: 0;
    width: 6%;
    background: linear-gradient(180deg, #d9521e 0%, #4cad70 100%);
    opacity: 0.7;
  }

  .edge-right {
    top: 14%;
    bottom: 14%;
    right: 0;
    width: 6%;
    background: linear-gradient(180deg, #66b4ff 0%, #d9521e 100%);
    opacity: 0.7;
  }

  .edge-screen {
    position: absolute;
    top: 20%;
    bottom: 20%;
    left: 10%;
    right: 10%;
    background: linear-gradient(135deg, rgba(217, 82, 30, 0.35), rgba(76, 173, 112, 0.3) 70%);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 3px;
  }

  /* Status bar */
  .app-status {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 0 12px;
    background: rgba(8, 9, 12, 0.9);
    border-top: 1px solid var(--lm-line);
    font-family: var(--lm-mono);
    font-size: 8.5px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--lm-ink-faint);
  }

  .app-status-pair {
    display: inline-flex;
    align-items: center;
    gap: 5px;
  }

  .app-status-pair .k {
    color: var(--lm-ink-faint);
  }

  .app-status-pair .v {
    color: var(--lm-ink-dim);
    display: inline-flex;
    align-items: center;
    gap: 4px;
  }

  .app-status-tele {
    margin-left: auto;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--lm-ink);
  }

  .app-status-tele b {
    color: var(--lm-amber);
    font-weight: 500;
  }

  .app-status-tele .tele-sep {
    width: 1px;
    height: 7px;
    background: var(--lm-line-2);
  }

  /* Mock collapses gracefully at narrow widths */
  @container (max-width: 520px) {
    .app-body {
      grid-template-columns: 120px 1fr;
    }
    .app-side {
      padding: 10px 9px;
      gap: 9px;
    }
    .app-main {
      padding: 12px 13px;
      gap: 11px;
    }
    .app-scenes {
      grid-template-columns: repeat(5, 1fr);
      gap: 4px;
    }
    .app-scenes li {
      font-size: 8.5px;
      padding: 5px 6px;
    }
    .edge-frame {
      max-width: 100%;
    }
    .app-chrome-tabs li {
      padding: 0 6px;
      font-size: 7.5px;
    }
    .app-status {
      gap: 9px;
      font-size: 7.5px;
    }
  }

  .dual-compact {
    max-width: 12rem;
    flex: 0 0 auto;
  }

  /* flex items default to min-width:auto (= min-content); for replaced
   * elements like <img> with an intrinsic width attribute that resolves
   * to the natural 900px dimension and blocks flex-shrink from
   * squeezing the element into the grid column. min-width:0 lets the
   * shrink actually apply. */
  .dual-full {
    flex: 1 1 0;
    min-width: 0;
  }

  /* ─── Feature grid ────────────────────────────────────── */
  .features {
    padding-block: 4rem;
  }

  .feature-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(18rem, 1fr));
    gap: 0.875rem;
    margin-top: 1rem;
  }

  .feature-grid article {
    padding: 1.75rem;
    background: var(--surface-1);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
  }

  .feature-icon {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: var(--tracking-wide);
    padding: 0.25rem 0.5rem;
    background: var(--accent-soft);
    color: var(--accent);
    display: inline-block;
    border-radius: var(--radius-sm);
    margin-bottom: 1rem;
  }

  .feature-grid h3 {
    font-size: var(--fs-lg);
    color: var(--text-primary);
    margin: 0 0 0.5rem;
  }

  .feature-grid p {
    color: var(--text-secondary);
    font-size: var(--fs-sm);
    line-height: var(--lh-relaxed);
    margin: 0 0 0.875rem;
  }

  .feature-grid a {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--text-muted);
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-out);
  }

  .feature-grid a:hover {
    color: var(--accent);
  }

  .feature-badges {
    list-style: none;
    margin: 0 0 0.875rem;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  .feature-badges li {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    padding: 0.125rem 0.5rem;
    background: var(--surface-2);
    color: var(--text-secondary);
    border: 1px solid var(--border);
    border-radius: var(--radius-pill);
  }

  /* ─── Callout (ambient, room map, tray-first) ─────────── */
  .callout {
    padding-block: 4rem;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: 3rem;
    align-items: center;
  }

  .callout.reverse {
    /* same grid; child order visually reversed on desktop */
  }

  .callout-copy {
    max-width: 28rem;
  }

  .callout-body {
    color: var(--text-secondary);
    font-size: var(--fs-md);
    line-height: var(--lh-relaxed);
    margin: 0 0 1rem;
  }

  .inline-cta {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--text-muted);
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-out);
  }

  .inline-cta:hover {
    color: var(--accent);
  }

  .callout-visual {
    position: relative;
    margin: 0;
  }

  .callout-visual.dual {
    display: flex;
    align-items: stretch;
    gap: 0.75rem;
  }

  .callout-visual.dual .hero-placeholder.full {
    flex: 1;
  }

  .telemetry-pill {
    position: absolute;
    bottom: 1rem;
    left: 1rem;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.375rem 0.75rem;
    background: rgba(10, 11, 14, 0.7);
    border: 1px solid var(--border-strong);
    border-radius: var(--radius-pill);
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    color: var(--text-primary);
    backdrop-filter: blur(8px);
  }

  .telemetry-pill strong {
    color: var(--accent);
    font-weight: 500;
    margin-right: 0.125rem;
  }

  .telemetry-pill .pill-eyebrow {
    padding: 0.0625rem 0.375rem;
    background: var(--accent);
    color: var(--text-inverse);
    border-radius: var(--radius-sm);
    font-size: 0.625rem;
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
  }

  .pill-sep {
    width: 1px;
    height: 0.75rem;
    background: var(--border-strong);
  }

  /* ─── Platforms ───────────────────────────────────────── */
  .platforms {
    padding-block: 4rem;
  }

  .platform-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(16rem, 1fr));
    gap: 0.75rem;
  }

  .platform-grid article {
    padding: 1.25rem 1.375rem;
    background: var(--surface-1);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
  }

  .platform-grid h3 {
    font-size: var(--fs-base);
    color: var(--text-primary);
    margin: 0 0 0.5rem;
    display: flex;
    align-items: center;
    gap: 0.625rem;
  }

  .platform-grid p {
    color: var(--text-secondary);
    font-size: var(--fs-sm);
    line-height: var(--lh-relaxed);
    margin: 0;
  }

  .tag {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    padding: 0.0625rem 0.4rem;
    border-radius: var(--radius-pill);
    font-weight: 500;
  }

  .tag-ok {
    background: var(--accent-soft);
    color: var(--accent);
  }

  .tag-warn {
    background: var(--surface-2);
    color: var(--text-muted);
    border: 1px solid var(--border);
  }

  /* ─── Trust ──────────────────────────────────────────── */
  .trust {
    padding-block: 4rem;
  }

  .trust-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(14rem, 1fr));
    gap: 2rem 2.5rem;
  }

  .trust-label {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--accent);
    margin: 0 0 0.5rem;
  }

  .trust-grid p {
    color: var(--text-secondary);
    font-size: var(--fs-sm);
    line-height: var(--lh-relaxed);
    margin: 0;
  }

  .trust-grid a {
    color: var(--text-primary);
    text-decoration: underline;
    text-decoration-color: var(--border-strong);
    text-underline-offset: 3px;
  }

  .trust-grid a:hover {
    text-decoration-color: var(--accent);
  }

  .trust-grid code {
    background: var(--surface-2);
    padding: 0.0625rem 0.375rem;
    border-radius: var(--radius-sm);
    font-size: 0.85em;
    color: var(--text-primary);
  }

  /* ─── Roadmap honesty ────────────────────────────────── */
  .roadmap {
    padding-block: 4rem;
  }

  .roadmap-lede {
    margin: 0 0 2rem;
    color: var(--text-secondary);
    font-size: var(--fs-md);
    line-height: var(--lh-relaxed);
    max-width: 44rem;
  }

  .roadmap-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(17rem, 1fr));
    gap: 0.75rem;
  }

  .roadmap-col {
    padding: 1.5rem 1.5rem 1.375rem;
    background: var(--surface-1);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .roadmap-col header {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .roadmap-col h3 {
    margin: 0;
    color: var(--text-primary);
    font-size: var(--fs-base);
    font-weight: 500;
  }

  .roadmap-col ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.5rem;
    font-size: var(--fs-sm);
    line-height: var(--lh-relaxed);
    color: var(--text-secondary);
    flex: 1;
  }

  .roadmap-col li {
    position: relative;
    padding-left: 1rem;
  }

  .roadmap-col li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.55rem;
    width: 0.375rem;
    height: 0.375rem;
    border-radius: 50%;
    background: var(--border-strong);
  }

  .roadmap-col code {
    background: var(--surface-2);
    padding: 0.0625rem 0.3rem;
    border-radius: var(--radius-sm);
    font-size: 0.85em;
    color: var(--text-primary);
  }

  .roadmap-caveat {
    margin: 0;
    color: var(--text-muted);
    font-size: var(--fs-xs);
    line-height: var(--lh-relaxed);
  }

  .roadmap-tag {
    display: inline-block;
    align-self: flex-start;
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: var(--tracking-wide);

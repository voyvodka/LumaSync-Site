---
import BaseLayout from '../layouts/BaseLayout.astro';

const recoveryLinks = [
  { href: '/', label: 'Home', desc: 'Landing, feature overview' },
  { href: '/docs', label: 'Docs', desc: 'Setup, hardware, troubleshooting' },
  { href: '/download', label: 'Download', desc: 'Latest installers' },
  { href: '/changelog', label: 'Changelog', desc: 'Release history' },
  {
    href: 'https://github.com/voyvodka/LumaSync/issues',
    label: 'Report a bug',
    desc: 'Open an issue on GitHub',
  },
];
---

<BaseLayout
  title="Not found"
  description="That page does not exist on lumasync.app. Links below go somewhere useful."
  noindex
>
  <section class="notfound">
    <div class="orb" aria-hidden="true"></div>

    <div class="inner">
      <p class="eyebrow">404 · Not found</p>
      <h1 class="page-title">This page isn’t wired in.</h1>
      <p class="sub">
        The URL you asked for does not exist on <code>lumasync.app</code>. It may have moved, or it
        was never here. The links below cover everything that is.
      </p>

      <div class="actions">
        <button type="button" class="search-cta" data-search-open>
          <svg viewBox="0 0 16 16" width="14" height="14" aria-hidden="true">
            <path
              d="M11 7a4 4 0 1 1-8 0 4 4 0 0 1 8 0Zm-.7 3.3a5.5 5.5 0 1 1 1-1l2.7 2.7-1 1-2.7-2.7Z"
              fill="currentColor"></path>
          </svg>
          Search
          <span class="kbd">
            <kbd>⌘</kbd><kbd>K</kbd>
          </span>
        </button>
        <a href="/" class="home-cta">← Home</a>
      </div>

      <ul role="list" class="recovery">
        {
          recoveryLinks.map((link) => (
            <li>
              <a href={link.href}>
                <span class="label">{link.label}</span>
                <span class="desc">{link.desc}</span>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </section>
</BaseLayout>

<style>
  .notfound {
    position: relative;
    max-width: calc(var(--container-content) + 2.5rem);
    margin-inline: auto;
    padding: 5rem 1.25rem 5rem;
    overflow: hidden;
  }

  .orb {
    position: absolute;
    top: -6rem;
    right: -6rem;
    width: 22rem;
    height: 22rem;
    border-radius: 999px;
    background: radial-gradient(
      closest-side,
      color-mix(in srgb, var(--accent) 28%, transparent),
      transparent 70%
    );
    filter: blur(24px);
    pointer-events: none;
    z-index: 0;
  }

  .inner {
    position: relative;
    z-index: 1;
  }

  h1 {
    font-size: var(--fs-3xl);
    margin: 0 0 1rem;
    max-width: 20ch;
  }

  .sub {
    color: var(--text-secondary);
    font-size: var(--fs-lg);
    line-height: var(--lh-relaxed);
    margin: 0 0 2rem;
    max-width: 36rem;
  }

  .sub code {
    background: var(--surface-2);
    padding: 0.0625rem 0.375rem;
    border-radius: var(--radius-sm);
    font-size: 0.85em;
  }

  .actions {
    display: flex;
    gap: 0.75rem;
    align-items: center;
    margin-bottom: 2.5rem;
    flex-wrap: wrap;
  }

  .search-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.625rem 0.875rem;
    background: var(--accent);
    color: var(--text-inverse);
    border: none;
    border-radius: var(--radius-md);
    font-family: var(--font-sans);
    font-size: var(--fs-sm);
    font-weight: 500;
    cursor: pointer;
    transition: background-color var(--duration-fast) var(--ease-out);
  }

  .search-cta:hover {
    background: var(--accent-strong);
  }

  .search-cta .kbd {
    display: inline-flex;
    gap: 0.125rem;
  }

  .search-cta kbd {
    background: rgba(10, 11, 14, 0.22);
    border: 1px solid rgba(10, 11, 14, 0.2);
    color: var(--text-inverse);
    font-size: 0.65rem;
    padding: 0.0625rem 0.3rem;
  }

  .home-cta {
    color: var(--text-secondary);
    text-decoration: none;
    font-size: var(--fs-sm);
    padding: 0.625rem 0.5rem;
    transition: color var(--duration-fast) var(--ease-out);
  }

  .home-cta:hover {
    color: var(--text-primary);
  }

  .recovery {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.5rem;
    grid-template-columns: repeat(auto-fit, minmax(15rem, 1fr));
  }

  .recovery a {
    display: block;
    padding: 0.875rem 1rem;
    background: var(--surface-1);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    text-decoration: none;
    transition:
      border-color var(--duration-fast) var(--ease-out),
      background-color var(--duration-fast) var(--ease-out);
  }

  .recovery a:hover {
    border-color: var(--border-strong);
    background: var(--surface-2);
  }

  .recovery .label {
    display: block;
    color: var(--text-primary);
    font-weight: 500;
    font-size: var(--fs-sm);
  }

  .recovery .desc {
    display: block;
    color: var(--text-muted);
    font-size: var(--fs-xs);
    margin-top: 0.125rem;
  }
</style>

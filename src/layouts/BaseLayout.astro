---
import '../styles/global.css';
import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SkipLink from '../components/SkipLink.astro';
import Search from '../components/Search.astro';
import Schema from '../components/Schema.astro';
import { organizationSchema, webSiteSchema } from '../lib/seo';

// Preload the three most-used font weights so @fontsource's font-face
// declarations don't block on a round-trip at first paint. Covers ~90%
// of above-the-fold glyphs (body 400, headings 600, mono eyebrows /
// kbd 400). Heavier weights (500) and Instrument Serif (hero h1 only)
// load lazily via the CSS @import in global.css. Vite's ?url import
// returns the hashed asset path after Astro's build, so the browser
// reuses the same file that @font-face points at — no double fetch.
import sans400 from '@fontsource/ibm-plex-sans/files/ibm-plex-sans-latin-400-normal.woff2?url';
import sans600 from '@fontsource/ibm-plex-sans/files/ibm-plex-sans-latin-600-normal.woff2?url';
import mono400 from '@fontsource/ibm-plex-mono/files/ibm-plex-mono-latin-400-normal.woff2?url';
// Instrument Serif is the hero-title face — above the fold on every
// page via .display / .page-title — so preloading it alongside the
// Plex trio keeps the first paint from flashing a serif-swap.
import serif400 from '@fontsource/instrument-serif/files/instrument-serif-latin-400-normal.woff2?url';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  noindex?: boolean;
  schemas?: unknown[];
}

const { title, description, canonical, ogImage, noindex, schemas = [] } = Astro.props;
const umamiSiteId = import.meta.env.PUBLIC_UMAMI_SITE_ID;
const umamiSrc = import.meta.env.PUBLIC_UMAMI_SRC;

// Beta stage forces noindex globally so staging deploys
// (beta.lumasync.app, *.pages.dev previews) don't leak into search +
// AI indexes. Set PUBLIC_SITE_STAGE=beta at build time on the beta
// Pages project; unset → production behaviour.
const isBetaStage = import.meta.env.PUBLIC_SITE_STAGE === 'beta';
const effectiveNoindex = noindex || isBetaStage;

// Organization + WebSite are emitted on every page. noindex pages opt out
// so draft content isn't published into the entity graph before review.
const baseSchemas = effectiveNoindex ? [] : [organizationSchema(), webSiteSchema()];
const allSchemas = [...baseSchemas, ...schemas];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/favicon-192.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="mask-icon" href="/brand/monogram.svg" color="#ffb020" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="author" href="/humans.txt" />
    <link rel="preload" as="font" type="font/woff2" crossorigin href={sans400} />
    <link rel="preload" as="font" type="font/woff2" crossorigin href={sans600} />
    <link rel="preload" as="font" type="font/woff2" crossorigin href={mono400} />
    <link rel="preload" as="font" type="font/woff2" crossorigin href={serif400} />
    <meta name="theme-color" content="#0a0b0e" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#ffb020" media="(prefers-color-scheme: light)" />
    <meta name="color-scheme" content="dark light" />
    <meta name="application-name" content="LumaSync" />
    <meta name="apple-mobile-web-app-title" content="LumaSync" />
    <meta name="format-detection" content="telephone=no" />
    <SEO
      title={title}
      description={description}
      canonical={canonical}
      ogImage={ogImage}
      noindex={effectiveNoindex}
    />
    <Schema schemas={allSchemas} />
    {
      umamiSiteId && umamiSrc && (
        <script is:inline defer data-website-id={umamiSiteId} src={umamiSrc} />
      )
    }
  </head>
  <body>
    <SkipLink />
    <Header />
    <main id="main" tabindex="-1">
      <slot />
    </main>
    <Footer />
    <Search />
  </body>
</html>

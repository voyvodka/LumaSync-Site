---
import '../styles/global.css';
import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SkipLink from '../components/SkipLink.astro';
import Search from '../components/Search.astro';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  noindex?: boolean;
}

const { title, description, canonical, ogImage, noindex } = Astro.props;
const umamiSiteId = import.meta.env.PUBLIC_UMAMI_SITE_ID;
const umamiSrc = import.meta.env.PUBLIC_UMAMI_SRC;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <SEO
      title={title}
      description={description}
      canonical={canonical}
      ogImage={ogImage}
      noindex={noindex}
    />
    {umamiSiteId && umamiSrc && <script defer data-website-id={umamiSiteId} src={umamiSrc} />}
  </head>
  <body>
    <SkipLink />
    <Header />
    <main id="main" tabindex="-1">
      <slot />
    </main>
    <Footer />
    <Search />
  </body>
</html>

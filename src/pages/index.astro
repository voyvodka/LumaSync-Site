---
import BaseLayout from '../layouts/BaseLayout.astro';
import { articleSchema, faqPageSchema, itemListSchema } from '../lib/seo';
import { LATEST_VERSION, LATEST_VERSION_DATE } from '../lib/version';

const title = 'LumaSync';
const description =
  'LumaSync mirrors your screen to WS2812B LED strips over USB and Philips Hue Entertainment areas at the same time, from one source. Local-only, brand-agnostic, MIT-licensed.';

const repo = 'https://github.com/voyvodka/LumaSync';

// Triple-stacked GEO schemas (Article + ItemList + FAQPage) — all
// reflect content that's actually rendered on the page below, so the
// markup adds context without spamming. dateModified ties to the
// pinned submodule's latest dated release, which is the freshest
// "site updated" signal we can quote without lying.
const schemas = [
  articleSchema({
    title: 'LumaSync — your screen, your lights. Locally.',
    description,
    url: '/',
    dateModified: LATEST_VERSION_DATE,
    image: '/og/landing.png',
  }),
  itemListSchema({
    name: 'LumaSync features',
    url: '/',
    items: [
      {
        name: 'USB LED strips',
        url: '/docs/usb-leds/serial-protocol',
        description:
          'Drives WS2812B strips through CH340 / FT232 USB-serial controllers running the LumaSync v1 serial frame at 115200 baud.',
      },
      {
        name: 'Philips Hue Entertainment streaming',
        url: '/docs/hue/entertainment-area',
        description:
          'DTLS 1.2 PSK streaming to any configured Entertainment Area at up to 20 Hz — the bridge ceiling.',
      },
      {
        name: 'Synchronized USB + Hue',
        url: '/docs/getting-started/first-setup',
        description:
          'A single screen-capture pipeline drives both targets simultaneously, switched per-mode from the system tray.',
      },
      {
        name: 'Room map editor',
        url: '/docs/usb-leds/calibration',
        description:
          'Drag-and-drop canvas for placing the TV anchor, furniture, USB strips, and Hue channels on a normalized grid.',
      },
      {
        name: 'Live Δ/Σ telemetry',
        url: '/docs/ambilight/performance',
        description:
          'Realtime frame-latency and FPS pill so you can see when the pipeline is healthy or stalling.',
      },
    ],
  }),
  faqPageSchema([
    {
      question: 'Does LumaSync need a cloud account?',
      answer:
        "No. LumaSync runs entirely on-device — no accounts, no telemetry, no cloud. Hue bridge pairing and configuration live in ~/.config/lumasync/app.json on your machine.",
    },
    {
      question: 'Can I use LumaSync with a console or Apple TV via HDMI?',
      answer:
        'No. LumaSync reads the OS screen buffer, so it cannot capture HDMI input from external devices. For HDMI sources the Philips Hue Sync Box is the right tool.',
    },
    {
      question: 'What hardware do I need?',
      answer:
        'Either a Philips Hue Bridge (gen 2 or newer) with at least one Entertainment Area configured, or a WS2812B LED strip driven by a CH340 / FT232 USB-serial controller running LumaSync firmware. Either path on its own is enough.',
    },
    {
      question: 'Is LumaSync free and open source?',
      answer:
        'Yes. LumaSync is MIT licensed. Source is at github.com/voyvodka/LumaSync — fork it, ship it, audit the screen-capture and streaming pipelines yourself.',
    },
    {
      question: 'Does LumaSync work on Linux?',
      answer:
        'Yes, experimentally. AppImage ships today and a Flathub submission is underway. Tray behaviour varies by desktop environment — GNOME needs an AppIndicator extension, and tiling window managers may force the window into a tile.',
    },
  ]),
];
---

<BaseLayout title={title} description={description} schemas={schemas}>
  {/* ─── Hero ───────────────────────────────────────────────── */}
  <section class="hero">
    <div class="hero-inner">
      <p class="eyebrow">Open source · Tauri 2 · MIT</p>
      <h1 class="display">Your screen, your lights. Locally.</h1>
      <p class="subhead">{description}</p>
      <div class="cta-row">
        <a class="cta-primary" href="/download" data-os-cta> Download </a>
        <a class="cta-secondary" href={repo}> View on GitHub → </a>
      </div>
      <p class="platform-note">macOS · Windows · Linux (experimental)</p>
    </div>

    <figure class="hero-visual">
      <picture>
        <source srcset="/media/hero-lights-section.webp" type="image/webp" />
        <img
          src="/media/hero-lights-section.png"
          width="1850"
          height="1460"
          alt="LumaSync's full-mode Lights section showing Ambilight active, scene presets, the live edge-signal preview, and the Δ/Σ telemetry pill."
          loading="eager"
          fetchpriority="high"
          decoding="async"
        />
      </picture>
    </figure>
  </section>

  {/* ─── "Both, at once" feature grid ───────────────────────── */}
  <section class="features">
    <p class="section-eyebrow">Both, at once</p>
    <h2 class="section-title">One pipeline. Two targets.</h2>
    <div class="feature-grid">
      <article>
        <div class="feature-icon" aria-hidden="true">USB</div>
        <h3>USB LED strips</h3>
        <p>
          CH340 and FT232 controllers at 115200 baud, running the
          <a href="/docs/usb-leds/serial-protocol">LumaSync v1 serial frame</a>. Opt-in Adalight
          profile shipped in v1.4.
        </p>
        <a href="/docs/usb-leds/controllers">Supported chipsets →</a>
      </article>

      <article>
        <div class="feature-icon" aria-hidden="true">HUE</div>
        <h3>Philips Hue Entertainment</h3>
        <p>
          DTLS 1.2 PSK streaming to any configured Entertainment Area. Up to 20 Hz — the bridge's
          real limit.
        </p>
        <a href="/docs/hue/entertainment-area">How Hue streaming works →</a>
      </article>

      <article>
        <div class="feature-icon" aria-hidden="true">⌃</div>
        <h3>Both, synchronized</h3>
        <p>
          Same screen source drives both targets. Pick per mode: USB, Hue, or both — switched from
          the tray.
        </p>
        <ul class="feature-badges" role="list" aria-label="Ships today">
          <li>Live Δ/Σ telemetry</li>
          <li>EN · TR i18n</li>
          <li>Compact 320×480 / Full 900×620</li>
        </ul>
        <a href="/docs/getting-started/first-setup">First-setup walkthrough →</a>
      </article>
    </div>
  </section>

  {/* ─── Ambient mode preview ──────────────────────────────── */}
  <section class="callout">
    <div class="callout-copy">
      <p class="section-eyebrow">Ambient mode</p>
      <h2 class="section-title">Real-time screen capture. 20 Hz update.</h2>
      <p class="callout-body">
        Tuned for latency, not flash. The telemetry pill shows live capture and send rates so you
        can see when the pipeline is healthy and when it isn't — no mystery numbers.
      </p>
      <a class="inline-cta" href="/docs/ambilight/performance">Read about performance →</a>
    </div>
    <figure class="callout-visual">
      <picture>
        <source srcset="/media/ambient-mode-preview.webp" type="image/webp" />
        <img
          src="/media/ambient-mode-preview.png"
          width="1850"
          height="1460"
          alt="LumaSync ambient mode with the edge-signal preview and live telemetry overlay."
          loading="lazy"
          decoding="async"
        />
      </picture>
      <div class="telemetry-pill" aria-hidden="true">
        <span class="pill-eyebrow">Live</span>
        <span><strong>Δ</strong> 12 ms</span>
        <span class="pill-sep"></span>
        <span><strong>Σ</strong> 60 fps</span>
      </div>
    </figure>
  </section>

  {/* ─── Room map editor ───────────────────────────────────── */}
  <section class="callout reverse">
    <figure class="callout-visual">
      <picture>
        <source srcset="/media/room-map-editor.webp" type="image/webp" />
        <img
          src="/media/room-map-editor.png"
          width="1850"
          height="1460"
          alt="LumaSync's room map editor canvas with a TV anchor, furniture objects, a USB strip, and Hue channel overlays."
          loading="lazy"
          decoding="async"
        />
      </picture>
    </figure>
    <div class="callout-copy">
      <p class="section-eyebrow">Room map editor</p>
      <h2 class="section-title">A canvas, not a config file.</h2>
      <p class="callout-body">
        Drag your TV, furniture, and USB strips onto a grid. Hue channels project onto normalized
        coordinates. Undo / redo, snap guides, keyboard shortcuts.
      </p>
      <a class="inline-cta" href="/docs/usb-leds/calibration">Calibration docs →</a>
    </div>
  </section>

  {/* ─── Menu-bar UX ─────────────────────────────────────── */}
  <section class="callout">
    <div class="callout-copy">
      <p class="section-eyebrow">Lives in the menu bar</p>
      <h2 class="section-title">Out of your way until you need it.</h2>
      <p class="callout-body">
        Single window hides to tray on close. Compact 320×480 mode for quick toggles, full 900×620
        mode when you want to configure. Auto-starts on login, if you want it to.
      </p>
      <a class="inline-cta" href="/docs/getting-started/first-setup">First-setup walkthrough →</a>
    </div>
    <figure class="callout-visual dual">
      <picture class="dual-compact">
        <source srcset="/media/compact-mode.webp" type="image/webp" />
        <img
          src="/media/compact-mode.png"
          width="640"
          height="960"
          alt="LumaSync compact mode — narrow window with mode tiles and scene picker."
          loading="lazy"
          decoding="async"
        />
      </picture>
      <picture class="dual-full">
        <source srcset="/media/full-mode.webp" type="image/webp" />
        <img
          src="/media/full-mode.png"
          width="1850"
          height="1460"
          alt="LumaSync full mode — main window with sidebar and Lights section open."
          loading="lazy"
          decoding="async"
        />
      </picture>
    </figure>
  </section>

  {/* ─── Platform support ──────────────────────────────────── */}
  <section class="platforms">
    <p class="section-eyebrow">Platform support</p>
    <h2 class="section-title">Installs anywhere you already work.</h2>
    <div class="platform-grid">
      <article>
        <h3>
          macOS
          <span class="tag tag-ok">Full support</span>
        </h3>
        <p>Primary development target. Universal binary (Apple Silicon + Intel).</p>
      </article>
      <article>
        <h3>
          Windows
          <span class="tag tag-ok">Supported</span>
        </h3>
        <p>MSI installer, winget in progress. USB + Hue paths fully functional.</p>
      </article>
      <article>
        <h3>
          Linux
          <span class="tag tag-warn">Experimental</span>
        </h3>
        <p>
          AppImage ships today, Flathub submission underway. Tray behavior varies by desktop
          environment.
        </p>
      </article>
    </div>
  </section>

  {/* ─── Open, signed, auditable ───────────────────────────── */}
  <section class="trust">
    <p class="section-eyebrow">Open · signed · auditable</p>
    <h2 class="section-title">No accounts. No telemetry. No cloud.</h2>
    <div class="trust-grid">
      <div>
        <p class="trust-label">MIT licensed</p>
        <p>Source at <a href={repo}>voyvodka/LumaSync</a>. Fork it, ship it, read it.</p>
      </div>
      <div>
        <p class="trust-label">Updates signed with minisign</p>
        <p>
          Every binary is signature-verified before replacing the on-disk version. <a
            href="/docs/advanced/auto-updater">How updates work</a
          >.
        </p>
      </div>
      <div>
        <p class="trust-label">Credentials stay local</p>
        <p>
          Hue bridge pairing and everything else lives in
          <code>~/.config/lumasync/app.json</code> on your machine.
        </p>
      </div>
    </div>
  </section>

  {/* ─── Roadmap honesty ───────────────────────────────────── */}
  <section class="roadmap">
    <p class="section-eyebrow">Transparent about scope</p>
    <h2 class="section-title">Roadmap honesty.</h2>
    <p class="roadmap-lede">
      No vaporware, no silently-aging footnotes. What shipped, what's queued, and what we've
      explicitly rejected — read end-to-end.
    </p>
    <div class="roadmap-grid">
      <article class="roadmap-col roadmap-shipped">
        <header>
          <span class="roadmap-tag tag-shipped">Shipped</span>
          <h3>{LATEST_VERSION} — {LATEST_VERSION_DATE}</h3>
        </header>
        <ul role="list">
          <li>USB per-LED sampling — each LED maps to its own edge region (replaces the v1.3 single-zone path)</li>
          <li>Opt-in Adalight firmware profile — reuse existing Adalight controllers without reflashing</li>
          <li>Per-channel color correction — R/G/B gamma, Kelvin white-balance, BT.601 saturation; same chain on USB and Hue</li>
          <li>Multi-monitor capture with stable display IDs and primary-display fallback on unplug</li>
          <li>StatusBar FPS / latency pill — green/amber/red thresholds, always visible while Ambilight is on</li>
          <li>Native OS notifications via <code>tauri-plugin-notification</code> + global ErrorBoundary fallback</li>
          <li>Keyboard shortcuts: ⌥1 / ⌥2 / ⌥3 to switch modes, ⌘, for Settings (TR-layout safe)</li>
          <li>Hue: richer pairing error codes, CLIP v2 room archetypes, three-step intensity presets</li>
        </ul>
        <a class="inline-cta" href="/changelog">Full changelog →</a>
      </article>

      <article class="roadmap-col roadmap-next">
        <header>
          <span class="roadmap-tag tag-next">Next</span>
          <h3>v1.5 — in flight</h3>
        </header>
        <ul role="list">
          <li>WLED sink — drive ESP32/ESP8266 boards over the LAN, on top of the v1.4 <code>LedSink</code> trait</li>
          <li>Companion firmware repo — reference sketch + PING/PONG handshake for v1 controllers</li>
          <li>OpenRGB sink (v2.0 track) — peripherals, motherboards, fans on the same pipeline</li>
        </ul>
        <p class="roadmap-caveat">
          No dates promised. The <code>LedSink</code> abstraction landed in v1.4 to make these tracks tractable.
        </p>
      </article>

      <article class="roadmap-col roadmap-rejected">
        <header>
          <span class="roadmap-tag tag-rejected">Never</span>
          <h3>DNA-conflicts</h3>
        </header>
        <ul role="list">
          <li>Daemon / headless mode — answered via a local HTTP API + Home Assistant</li>
          <li>Cloud telemetry or Sentry-class reporting — privacy posture is load-bearing</li>
          <li>Cloud scene gallery — local files and JSON export only</li>
          <li>AI-prompt scene inference — cloud inference breaks the zero-network promise</li>
          <li>Docker / headless Linux server distribution — tray-first DNA</li>
        </ul>
        <p class="roadmap-caveat">These are rejections, not "not yet" items.</p>
      </article>
    </div>
  </section>

  {/* ─── Not for you if… ───────────────────────────────────── */}
  <section class="filter">
    <p class="section-eyebrow">Honest filter</p>
    <h2 class="section-title">Not for you if…</h2>
    <ul role="list">
      <li>
        <strong>You need HDMI passthrough for a console or Apple TV.</strong>
        LumaSync reads the OS screen buffer — no HDMI in the signal path. Grab a <a
          href="/compare/hue-sync">Hue Sync Box</a
        > instead.
      </li>
      <li>
        <strong>You don't have a Hue Bridge or a WS2812B controller.</strong>
        The app will run, but you won't see anything light up. Start with the <a
          href="/docs/getting-started/hardware-checklist">hardware checklist</a
        >.
      </li>
      <li>
        <strong>You're on an unusual Linux desktop environment.</strong>
        Tray behavior varies — GNOME needs an AppIndicator extension, tiling WMs may force windows into
        tiles. Community-driven support on Linux for now.
      </li>
    </ul>
  </section>
</BaseLayout>

<script is:inline>
  (() => {
    const btn = document.querySelector('[data-os-cta]');
    if (!btn) return;
    const ua = navigator.userAgent;
    const label = /Windows/i.test(ua)
      ? 'Download for Windows'
      : /Linux/i.test(ua) || /X11/i.test(ua)
        ? 'Download for Linux'
        : /Mac|macOS/i.test(ua)
          ? 'Download for macOS'
          : 'Download';
    btn.textContent = label;
  })();
</script>

<style>
  /* ─── Shared ────────────────────────────────────────────── */
  .hero,
  .features,
  .callout,
  .platforms,
  .trust,
  .roadmap,
  .filter {
    max-width: calc(var(--container-wide) + 2.5rem);
    margin-inline: auto;
    padding-inline: 1.25rem;
  }

  .section-eyebrow {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--accent);
    margin: 0 0 0.75rem;
  }

  .section-title {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: var(--fs-3xl);
    line-height: var(--lh-tight);
    letter-spacing: var(--tracking-tight);
    color: var(--text-primary);
    margin: 0 0 1.5rem;
    max-width: 28ch;
  }

  /* ─── Hero ────────────────────────────────────────────── */
  .hero {
    padding-block: 5rem 4rem;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.1fr);
    gap: 3rem;
    align-items: center;
  }

  .hero-inner .eyebrow {
    margin: 0 0 1.25rem;
  }

  .hero h1.display {
    font-size: var(--fs-hero);
    color: var(--text-primary);
    margin: 0 0 1.125rem;
    max-width: 16ch;
  }

  .subhead {
    color: var(--text-secondary);
    font-size: var(--fs-lg);
    line-height: var(--lh-relaxed);
    margin: 0 0 2rem;
    max-width: 34rem;
  }

  .cta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: center;
  }

  .cta-primary,
  .cta-secondary {
    display: inline-flex;
    align-items: center;
    padding: 0.75rem 1.125rem;
    border-radius: var(--radius-md);
    font-weight: 500;
    text-decoration: none;
    font-size: var(--fs-sm);
    transition:
      background-color var(--duration-fast) var(--ease-out),
      border-color var(--duration-fast) var(--ease-out);
  }

  .cta-primary {
    background: var(--accent);
    color: var(--text-inverse);
  }

  .cta-primary:hover {
    background: var(--accent-strong);
  }

  .cta-secondary {
    border: 1px solid var(--border-strong);
    background: var(--surface-1);
    color: var(--text-primary);
  }

  .cta-secondary:hover {
    background: var(--surface-2);
  }

  .platform-note {
    margin-top: 1.5rem;
    color: var(--text-muted);
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    letter-spacing: var(--tracking-wide);
  }

  /* Real-image visuals shared by hero + callouts */
  /* Screenshots ship with their own window chrome + drop shadow — no
   * extra border/radius here so we don't stack two frames around the
   * same edge. */
  .hero-visual img,
  .callout-visual img {
    display: block;
    width: 100%;
    height: auto;
  }

  .dual-compact {
    max-width: 12rem;
    flex: 0 0 auto;
  }

  /* flex items default to min-width:auto (= min-content); for replaced
   * elements like <img> with an intrinsic width attribute that resolves
   * to the natural 900px dimension and blocks flex-shrink from
   * squeezing the element into the grid column. min-width:0 lets the
   * shrink actually apply. */
  .dual-full {
    flex: 1 1 0;
    min-width: 0;
  }

  /* ─── Feature grid ────────────────────────────────────── */
  .features {
    padding-block: 4rem;
  }

  .feature-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(18rem, 1fr));
    gap: 0.875rem;
    margin-top: 1rem;
  }

  .feature-grid article {
    padding: 1.75rem;
    background: var(--surface-1);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
  }

  .feature-icon {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: var(--tracking-wide);
    padding: 0.25rem 0.5rem;
    background: var(--accent-soft);
    color: var(--accent);
    display: inline-block;
    border-radius: var(--radius-sm);
    margin-bottom: 1rem;
  }

  .feature-grid h3 {
    font-size: var(--fs-lg);
    color: var(--text-primary);
    margin: 0 0 0.5rem;
  }

  .feature-grid p {
    color: var(--text-secondary);
    font-size: var(--fs-sm);
    line-height: var(--lh-relaxed);
    margin: 0 0 0.875rem;
  }

  .feature-grid a {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--text-muted);
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-out);
  }

  .feature-grid a:hover {
    color: var(--accent);
  }

  .feature-badges {
    list-style: none;
    margin: 0 0 0.875rem;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  .feature-badges li {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    padding: 0.125rem 0.5rem;
    background: var(--surface-2);
    color: var(--text-secondary);
    border: 1px solid var(--border);
    border-radius: var(--radius-pill);
  }

  /* ─── Callout (ambient, room map, tray-first) ─────────── */
  .callout {
    padding-block: 4rem;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: 3rem;
    align-items: center;
  }

  .callout.reverse {
    /* same grid; child order visually reversed on desktop */
  }

  .callout-copy {
    max-width: 28rem;
  }

  .callout-body {
    color: var(--text-secondary);
    font-size: var(--fs-md);
    line-height: var(--lh-relaxed);
    margin: 0 0 1rem;
  }

  .inline-cta {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--text-muted);
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-out);
  }

  .inline-cta:hover {
    color: var(--accent);
  }

  .callout-visual {
    position: relative;
    margin: 0;
  }

  .callout-visual.dual {
    display: flex;
    align-items: stretch;
    gap: 0.75rem;
  }

  .callout-visual.dual .hero-placeholder.full {
    flex: 1;
  }

  .telemetry-pill {
    position: absolute;
    bottom: 1rem;
    left: 1rem;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.375rem 0.75rem;
    background: rgba(10, 11, 14, 0.7);
    border: 1px solid var(--border-strong);
    border-radius: var(--radius-pill);
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    color: var(--text-primary);
    backdrop-filter: blur(8px);
  }

  .telemetry-pill strong {
    color: var(--accent);
    font-weight: 500;
    margin-right: 0.125rem;
  }

  .telemetry-pill .pill-eyebrow {
    padding: 0.0625rem 0.375rem;
    background: var(--accent);
    color: var(--text-inverse);
    border-radius: var(--radius-sm);
    font-size: 0.625rem;
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
  }

  .pill-sep {
    width: 1px;

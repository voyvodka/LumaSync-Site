---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import CompareCTA from '../../components/CompareCTA.astro';
import { articleSchema, breadcrumbSchema } from '../../lib/seo';

export async function getStaticPaths() {
  const entries = await getCollection('compare');
  return entries.map((entry) => ({
    params: { slug: entry.id.replace(/\.mdx$/, '') },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { slug } = Astro.params;
const { Content } = await render(entry);

const updatedISO = entry.data.updated.toISOString().slice(0, 10);

const schemas = entry.data.draft
  ? []
  : [
      breadcrumbSchema([
        { name: 'Home', url: '/' },
        { name: 'Compare', url: '/compare' },
        { name: `vs ${entry.data.competitor}`, url: `/compare/${slug}` },
      ]),
      articleSchema({
        title: entry.data.title,
        description: entry.data.description,
        url: `/compare/${slug}`,
        dateModified: updatedISO,
      }),
    ];
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.description}
  noindex={entry.data.draft}
  schemas={schemas}
>
  <article class="compare" data-pagefind-body>
    <header>
      <p class="eyebrow">LumaSync vs {entry.data.competitor}</p>
      <h1>{entry.data.title}</h1>
      <p class="desc">{entry.data.description}</p>
    </header>
    <div class="prose">
      <Content />
    </div>
    <CompareCTA competitor={slug} />
  </article>
</BaseLayout>

<style>
  .compare {
    max-width: 44rem;
    margin: 0 auto;
    padding: 4rem 1.25rem 6rem;
  }

  .eyebrow {
    color: var(--accent);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin: 0 0 0.75rem;
  }

  h1 {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 4vw, 2.75rem);
    margin: 0 0 0.75rem;
    color: var(--text-primary);
  }

  .desc {
    color: var(--text-secondary);
    margin: 0 0 2rem;
    font-size: 1.05rem;
  }

  .prose :global(p) {
    line-height: 1.65;
    color: var(--text-secondary);
  }

  .prose :global(table) {
    border-collapse: collapse;
    width: 100%;
    margin: 1.5rem 0;
  }

  .prose :global(th),
  .prose :global(td) {
    border: 1px solid var(--border);
    padding: 0.5rem 0.75rem;
    text-align: left;
  }
</style>

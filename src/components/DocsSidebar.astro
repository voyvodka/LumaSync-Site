---
import { groupDocs, docHref } from '../lib/content';

interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;
const groups = await groupDocs();
const normalized = currentPath.replace(/\/$/, '');
---

<aside class="docs-sidebar" aria-label="Documentation navigation" data-pagefind-ignore>
  <nav>
    {
      groups.length === 0 && (
        <p class="empty">No docs yet. Published pages will appear here.</p>
      )
    }
    {
      groups.map((group) => (
        <section>
          <p class="group-label">{group.label}</p>
          <ul role="list">
            {group.items.map((item) => {
              const href = docHref(item);
              const active = normalized === href.replace(/\/$/, '');
              return (
                <li>
                  <a href={href} aria-current={active ? 'page' : undefined}>
                    <span class="title">{item.data.title}</span>
                    {item.data.draft && <span class="pill">draft</span>}
                  </a>
                </li>
              );
            })}
          </ul>
        </section>
      ))
    }
  </nav>
</aside>

<style>
  .docs-sidebar {
    position: sticky;
    top: calc(3.5rem + 1rem);
    align-self: start;
  }

  nav {
    display: grid;
    gap: 1.5rem;
  }

  section {
    display: grid;
    gap: 0.375rem;
  }

  .group-label {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--text-muted);
    margin: 0 0 0.25rem;
  }

  ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.125rem;
  }

  a {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    padding: 0.375rem 0.625rem;
    margin-inline: -0.625rem;
    border-radius: var(--radius-sm);
    text-decoration: none;
    color: var(--text-secondary);
    font-size: var(--fs-sm);
    line-height: var(--lh-snug);
    transition:
      color var(--duration-fast) var(--ease-out),
      background-color var(--duration-fast) var(--ease-out);
  }

  a:hover {
    color: var(--text-primary);
    background: var(--surface-1);
  }

  a[aria-current='page'] {
    color: var(--text-primary);
    background: var(--surface-2);
    box-shadow: inset 2px 0 0 var(--accent);
  }

  .title {
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .pill {
    flex-shrink: 0;
    font-family: var(--font-mono);
    font-size: 0.625rem;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    padding: 0.0625rem 0.375rem;
    border-radius: var(--radius-pill);
    background: var(--accent-soft);
    color: var(--accent);
  }

  .empty {
    color: var(--text-muted);
    font-size: var(--fs-sm);
    margin: 0;
  }

  @media (max-width: 900px) {
    .docs-sidebar {
      position: static;
      max-height: 14rem;
      overflow-y: auto;
      padding: 1rem;
      border: 1px solid var(--border);
      border-radius: var(--radius-lg);
      background: var(--surface-1);
    }
  }
</style>

---
import Container from './Container.astro';

const year = new Date().getFullYear();
const repo = import.meta.env.PUBLIC_GITHUB_REPO ?? 'https://github.com/voyvodka/LumaSync';

const columns = [
  {
    label: 'Product',
    links: [
      { href: '/download', label: 'Download' },
      { href: '/docs', label: 'Docs' },
      { href: '/changelog', label: 'Changelog' },
      { href: '/compare', label: 'Compare' },
    ],
  },
  {
    label: 'Community',
    links: [
      { href: repo, label: 'GitHub' },
      { href: `${repo}/releases`, label: 'Releases' },
      { href: `${repo}/discussions`, label: 'Discussions' },
    ],
  },
  {
    label: 'Legal',
    links: [
      { href: '/privacy', label: 'Privacy' },
      { href: '/license', label: 'License' },
      { href: '/.well-known/security.txt', label: 'Security' },
    ],
  },
];
---

<footer class="site-footer" data-pagefind-ignore>
  <Container size="wide">
    <div class="grid">
      <div class="brand-block">
        <p class="brand">
          <span class="brand-dot" aria-hidden="true"></span>
          <span class="brand-name">LumaSync</span>
        </p>
        <p class="tagline">
          Tray-first ambilight + Philips Hue Entertainment. Open source, no cloud, no HDMI box.
        </p>
      </div>

      {
        columns.map((col) => (
          <nav aria-label={col.label} class="column">
            <p class="column-label">{col.label}</p>
            <ul role="list">
              {col.links.map((link) => (
                <li>
                  <a href={link.href}>{link.label}</a>
                </li>
              ))}
            </ul>
          </nav>
        ))
      }
    </div>

    <div class="bottom">
      <p>© {year} voyvodka · MIT licensed</p>
      <p class="built-with">Built with Tauri 2 + React 19</p>
    </div>
  </Container>
</footer>

<style>
  .site-footer {
    margin-top: 6rem;
    padding-block: 3rem 3.5rem;
    border-top: 1px solid var(--border);
    color: var(--text-secondary);
  }

  .grid {
    display: grid;
    grid-template-columns: 2fr repeat(3, 1fr);
    gap: 2.5rem 2rem;
    align-items: start;
  }

  .brand-block {
    max-width: 22rem;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--text-primary);
    font-weight: 500;
    margin: 0 0 0.5rem;
  }

  .brand-dot {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: var(--radius-pill);
    background: var(--accent);
    box-shadow: var(--shadow-ring);
  }

  .tagline {
    color: var(--text-muted);
    font-size: var(--fs-sm);
    line-height: var(--lh-relaxed);
    margin: 0;
  }

  .column-label {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--text-muted);
    margin: 0 0 0.75rem;
  }

  .column ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.5rem;
  }

  .column a {
    color: var(--text-secondary);
    text-decoration: none;
    font-size: var(--fs-sm);
    transition: color var(--duration-fast) var(--ease-out);
  }

  .column a:hover {
    color: var(--text-primary);
  }

  .bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 2.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
    font-size: var(--fs-xs);
    color: var(--text-muted);
  }

  .bottom p {
    margin: 0;
  }

  .built-with {
    font-family: var(--font-mono);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
  }

  @media (max-width: 720px) {
    .grid {
      grid-template-columns: 1fr 1fr;
    }

    .brand-block {
      grid-column: 1 / -1;
    }

    .bottom {
      flex-direction: column;
      gap: 0.75rem;
      align-items: flex-start;
    }
  }
</style>

---
import Container from './Container.astro';

const links = [
  { href: '/docs', label: 'Docs' },
  { href: '/download', label: 'Download' },
  { href: '/changelog', label: 'Changelog' },
  { href: '/compare', label: 'Compare' },
  { href: '/community', label: 'Community' },
];

const pathname = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? pathname === '/' : pathname === href || pathname.startsWith(`${href}/`);
---

<header class="site-header" data-pagefind-ignore>
  <Container size="wide">
    <nav aria-label="Primary">
      <a href="/" class="brand" aria-label="LumaSync home">
        <svg class="brand-mark" viewBox="0 0 64 64" width="18" height="18" aria-hidden="true">
          <path d="M35 9.85 L42.6 12.31 L29 54.15 L21.4 51.69 Z" fill="#ffb020"></path>
        </svg>
        <span class="brand-name">LumaSync</span>
      </a>
      <ul role="list">
        {
          links.map(({ href, label }) => (
            <li>
              <a href={href} aria-current={isActive(href) ? 'page' : undefined}>
                {label}
              </a>
            </li>
          ))
        }
      </ul>
      <button type="button" class="search-trigger" data-search-open aria-label="Open search">
        <svg viewBox="0 0 16 16" width="14" height="14" aria-hidden="true">
          <path
            d="M11 7a4 4 0 1 1-8 0 4 4 0 0 1 8 0Zm-.7 3.3a5.5 5.5 0 1 1 1-1l2.7 2.7-1 1-2.7-2.7Z"
            fill="currentColor"></path>
        </svg>
        <span class="search-kbd">
          <kbd>⌘</kbd><kbd>K</kbd>
        </span>
      </button>
    </nav>
  </Container>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: var(--surface-overlay);
    backdrop-filter: saturate(160%) blur(10px);
    -webkit-backdrop-filter: saturate(160%) blur(10px);
    border-bottom: 1px solid var(--border);
  }

  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    padding-block: 0.875rem;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--text-primary);
    text-decoration: none;
    font-weight: 500;
    letter-spacing: var(--tracking-snug);
  }

  .brand-mark {
    flex-shrink: 0;
    display: block;
  }

  .brand-name {
    font-size: var(--fs-base);
  }

  ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  li a {
    color: var(--text-secondary);
    text-decoration: none;
    font-size: var(--fs-sm);
    padding: 0.25rem 0;
    border-bottom: 2px solid transparent;
    transition:
      color var(--duration-fast) var(--ease-out),
      border-color var(--duration-fast) var(--ease-out);
  }

  li a:hover {
    color: var(--text-primary);
  }

  li a[aria-current='page'] {
    color: var(--text-primary);
    border-bottom-color: var(--accent);
  }

  .search-trigger {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.3125rem 0.5rem 0.3125rem 0.625rem;
    background: var(--surface-1);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    color: var(--text-muted);
    cursor: pointer;
    transition:
      border-color var(--duration-fast) var(--ease-out),
      color var(--duration-fast) var(--ease-out);
  }

  .search-trigger:hover {
    border-color: var(--border-strong);
    color: var(--text-primary);
  }

  .search-trigger .search-kbd {
    display: inline-flex;
    gap: 0.125rem;
  }

  .search-trigger kbd {
    font-size: 0.65rem;
    padding: 0.0625rem 0.3rem;
    background: var(--surface-2);
    border: 1px solid var(--border);
    color: var(--text-muted);
  }

  @media (max-width: 640px) {
    ul {
      gap: 1rem;
      font-size: 0.8rem;
    }

    li a {
      font-size: 0.8rem;
    }

    /* Drop the least-essential link first on narrow viewports */
    li:nth-child(5) {
      display: none;
    }

    .search-trigger {
      padding: 0.3125rem 0.5rem;
    }
  }

  @media (max-width: 460px) {
    li:nth-child(4) {
      display: none;
    }
  }
</style>

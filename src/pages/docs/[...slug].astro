---
import { render } from 'astro:content';
import DocsLayout from '../../layouts/DocsLayout.astro';
import { listDocs, DOC_GROUP_LABELS } from '../../lib/content';

export async function getStaticPaths() {
  const entries = await listDocs();
  return entries.map((entry) => ({
    params: { slug: entry.id.replace(/\.mdx$/, '') },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const groupLabel = DOC_GROUP_LABELS[entry.data.group];
---

<DocsLayout title={entry.data.title} description={entry.data.description}>
  <article class="doc">
    <header>
      <p class="crumb">
        <a href="/docs">Docs</a>
        <span aria-hidden="true">·</span>
        <span>{groupLabel}</span>
      </p>
      <h1 class="display">{entry.data.title}</h1>
      <p class="desc">{entry.data.description}</p>
      {
        entry.data.draft && (
          <p class="draft-banner" role="note">
            <span class="pill">draft</span>
            This page is awaiting owner review. Content may change.
          </p>
        )
      }
    </header>
    <div class="prose">
      <Content />
    </div>
  </article>
</DocsLayout>

<style>
  .doc header {
    margin-bottom: 2.5rem;
  }

  .crumb {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--text-muted);
    display: inline-flex;
    gap: 0.5rem;
    margin: 0 0 1rem;
  }

  .crumb a {
    color: var(--text-secondary);
    text-decoration: none;
  }

  .crumb a:hover {
    color: var(--accent);
  }

  h1 {
    font-size: var(--fs-3xl);
    color: var(--text-primary);
    margin: 0 0 0.75rem;
  }

  .desc {
    color: var(--text-secondary);
    font-size: var(--fs-lg);
    line-height: var(--lh-relaxed);
    margin: 0;
  }

  .draft-banner {
    margin-top: 1.25rem;
    padding: 0.75rem 1rem;
    background: var(--accent-soft);
    border: 1px solid var(--border-accent);
    border-radius: var(--radius-md);
    color: var(--text-primary);
    font-size: var(--fs-sm);
    display: flex;
    align-items: center;
    gap: 0.625rem;
  }

  .pill {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    padding: 0.0625rem 0.4rem;
    border-radius: var(--radius-pill);
    background: var(--accent);
    color: var(--text-inverse);
    font-weight: 500;
  }
</style>

---
import { readFile } from 'node:fs/promises';
import { resolve } from 'node:path';
import { marked } from 'marked';
import BaseLayout from '../layouts/BaseLayout.astro';

// Sourced from vendor/lumasync/CHANGELOG.md at the pinned submodule ref.
// Single source per .thinking/02-website.md § #3 — bumping the submodule
// is the only way changelog content reaches the site.
//
// process.cwd() is the Astro project root at build time, so this path is
// stable whether the page runs from src/ during dev or from a bundled
// chunk during SSG build.
const changelogPath = resolve(process.cwd(), 'vendor/lumasync/CHANGELOG.md');
const repo = 'https://github.com/voyvodka/LumaSync';

marked.setOptions({
  gfm: true,
  breaks: false,
});

let html: string | null = null;
let raw: string | null = null;

try {
  raw = await readFile(changelogPath, 'utf-8');
  // Strip the leading "# Changelog" heading — the page header renders
  // an h1 already, and we want the first version section to lead the body.
  const normalised = raw.replace(/^#\s+Changelog\s*$/m, '');
  html = await marked.parse(normalised);
} catch {
  html = null;
}
---

<BaseLayout
  title="Changelog"
  description="Release history for LumaSync, synced from the app repo at the pinned submodule ref."
>
  <article class="changelog">
    <header>
      <p class="eyebrow">Release history</p>
      <h1 class="display">Changelog</h1>
      <p class="lede">
        Sourced from{' '}
        <a href={`${repo}/blob/main/CHANGELOG.md`}><code>voyvodka/LumaSync</code></a>
        {' '}at the pinned submodule ref. This page redeploys when the submodule is
        bumped — see <a href={`${repo}/releases`}>Releases</a> for signed binaries.
      </p>
    </header>

    {
      html ? (
        <div class="changelog-body" set:html={html} />
      ) : (
        <div class="missing">
          <p>
            <strong>Changelog not available at build time.</strong>{' '}
            The <code>vendor/lumasync/</code> submodule is not initialised in this
            checkout. Run <code>git submodule update --init --recursive</code> and
            rebuild.
          </p>
        </div>
      )
    }
  </article>
</BaseLayout>

<style>
  .changelog {
    max-width: calc(var(--container-content) + 2.5rem);
    margin-inline: auto;
    padding: 3rem 1.25rem 5rem;
  }

  header {
    margin-bottom: 2.5rem;
  }

  h1 {
    font-size: var(--fs-3xl);
    margin: 0 0 0.75rem;
  }

  .lede {
    color: var(--text-secondary);
    font-size: var(--fs-lg);
    line-height: var(--lh-relaxed);
    margin: 0;
    max-width: 36rem;
  }

  .lede code {
    background: var(--surface-2);
    padding: 0.0625rem 0.375rem;
    border-radius: var(--radius-sm);
    font-size: 0.85em;
  }

  .lede a {
    color: var(--text-primary);
    text-decoration: underline;
    text-decoration-color: var(--border-strong);
    text-underline-offset: 3px;
  }

  .lede a:hover {
    text-decoration-color: var(--accent);
  }

  /* ─── Rendered markdown body ───────────────────── */
  .changelog-body {
    font-size: var(--fs-md);
    color: var(--text-secondary);
    line-height: var(--lh-relaxed);
  }

  .changelog-body :global(h2) {
    font-family: var(--font-display);
    font-size: var(--fs-2xl);
    margin-top: 2.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
    color: var(--text-primary);
    letter-spacing: var(--tracking-tight);
    line-height: var(--lh-tight);
  }

  .changelog-body :global(h2:first-of-type) {
    border-top: none;
    padding-top: 0;
    margin-top: 0;
  }

  .changelog-body :global(h3) {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--accent);
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
    font-weight: 500;
  }

  .changelog-body :global(p) {
    margin: 0 0 1rem;
  }

  .changelog-body :global(ul),
  .changelog-body :global(ol) {
    padding-left: 1.25rem;
    margin: 0 0 1rem;
  }

  .changelog-body :global(li) {
    margin-bottom: 0.25rem;
  }

  .changelog-body :global(li::marker) {
    color: var(--text-muted);
  }

  .changelog-body :global(a) {
    color: var(--text-primary);
    text-decoration: underline;
    text-decoration-color: var(--border-strong);
    text-underline-offset: 3px;
  }

  .changelog-body :global(a:hover) {
    text-decoration-color: var(--accent);
  }

  .changelog-body :global(code) {
    background: var(--surface-2);
    padding: 0.125rem 0.375rem;
    border-radius: var(--radius-sm);
    font-size: 0.85em;
    color: var(--text-primary);
  }

  .changelog-body :global(strong) {
    color: var(--text-primary);
  }

  .missing {
    padding: 1.5rem;
    background: var(--surface-1);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    color: var(--text-secondary);
    line-height: var(--lh-relaxed);
  }

  .missing code {
    background: var(--surface-2);
    padding: 0.125rem 0.375rem;
    border-radius: var(--radius-sm);
    font-size: 0.9em;
    color: var(--text-primary);
  }
</style>

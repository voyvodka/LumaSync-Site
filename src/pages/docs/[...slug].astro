---
import { render } from 'astro:content';
import DocsLayout from '../../layouts/DocsLayout.astro';
import { listDocs, DOC_GROUP_LABELS } from '../../lib/content';
import { breadcrumbSchema, howToSchema, techArticleSchema, type HowToInput } from '../../lib/seo';

export async function getStaticPaths() {
  const entries = await listDocs();
  return entries.map((entry) => ({
    params: { slug: entry.id.replace(/\.mdx$/, '') },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const groupLabel = DOC_GROUP_LABELS[entry.data.group];
const slug = entry.id.replace(/\.mdx$/, '');
const docPath = `/docs/${slug}`;

// HowTo schemas for the step-by-step getting-started guides. Each
// step.text is a self-contained instruction so Google rich-result
// eligibility stays intact; the docs page itself carries the full
// prose. Keyed by slug so the Astro build emits the schema only for
// the matching MDX entry.
const HOWTO_BY_SLUG: Record<string, Omit<HowToInput, 'url'>> = {
  'getting-started/install': {
    name: 'Install LumaSync',
    description:
      'Install LumaSync on macOS, Windows, or Linux from a signed binary, then verify the signature before first launch.',
    totalTime: 'PT5M',
    steps: [
      {
        name: 'Check prerequisites',
        text: 'Confirm you are on macOS 13+, Windows 10+, or a mainstream Linux desktop, and that you have either a Philips Hue Bridge with an Entertainment Area or a WS2812B strip driven by a CH340 or FT232 USB-serial controller.',
        url: '/docs/getting-started/install#prerequisites',
      },
      {
        name: 'Download for your OS',
        text: 'Open the Download page and choose the build matching your operating system. macOS ships as a universal .dmg, Windows as an MSI installer, Linux as an AppImage.',
        url: '/download',
      },
      {
        name: 'Install the binary',
        text: 'Run the installer (macOS / Windows) or move the AppImage somewhere on PATH and chmod +x it (Linux). LumaSync is a single application, no background service to manage.',
        url: '/docs/getting-started/install',
      },
      {
        name: 'Verify the signature',
        text: 'On first launch the auto-updater verifies the minisign signature against the bundled public key. If verification fails the install aborts — re-download from a clean source.',
        url: '/docs/advanced/auto-updater',
      },
      {
        name: 'Run the first-setup walkthrough',
        text: 'Launch LumaSync and follow the in-app first-setup flow to pair your Hue bridge or connect your USB controller and confirm lights are responding.',
        url: '/docs/getting-started/first-setup',
      },
    ],
  },
  'getting-started/first-setup': {
    name: 'First setup walkthrough',
    description:
      'Pair LumaSync with your Hue bridge or USB controller, pick a scene preset, and confirm lights respond — start to first sync in under five minutes.',
    totalTime: 'PT5M',
    steps: [
      {
        name: 'Open LumaSync and pick a target',
        text: 'Launch LumaSync. The first-run flow asks whether you want to drive a Hue Entertainment Area, a USB LED strip, or both.',
      },
      {
        name: 'Pair your Hue bridge (Hue path)',
        text: 'Press the link button on top of the Hue bridge, then click Pair in LumaSync within thirty seconds. The bridge issues an application key that LumaSync stores locally.',
        url: '/docs/hue/pairing',
      },
      {
        name: 'Plug in your USB controller (USB path)',
        text: 'Connect the CH340 or FT232 controller via USB. LumaSync detects the chipset and prompts you to assign it to a strip in the room map.',
        url: '/docs/usb-leds/controllers',
      },
      {
        name: 'Pick a scene preset',
        text: 'Open the scenes panel and pick Ambilight, Solid colour, or one of the gradient presets. The lights should mirror the screen within milliseconds.',
        url: '/docs/advanced/scenes',
      },
      {
        name: 'Watch the Δ/Σ telemetry pill',
        text: 'Confirm capture and send rates are healthy — Δ should sit under 20 ms and Σ should match your screen refresh rate. If either drifts, see the performance docs for tuning.',
        url: '/docs/ambilight/performance',
      },
    ],
  },
};

const howto = HOWTO_BY_SLUG[slug];

const schemas = entry.data.draft
  ? []
  : [
      breadcrumbSchema([
        { name: 'Home', url: '/' },
        { name: 'Docs', url: '/docs' },
        { name: groupLabel, url: '/docs' },
        { name: entry.data.title, url: docPath },
      ]),
      techArticleSchema({
        title: entry.data.title,
        description: entry.data.description,
        url: docPath,
        dateModified: entry.data.updated.toISOString(),
        section: groupLabel,
      }),
      ...(howto ? [howToSchema({ ...howto, url: docPath })] : []),
    ];
---

<DocsLayout
  title={entry.data.title}
  description={entry.data.description}
  noindex={entry.data.draft}
  schemas={schemas}
>
  <article class="doc">
    <header>
      <p class="crumb">
        <a href="/docs">Docs</a>
        <span aria-hidden="true">·</span>
        <span>{groupLabel}</span>
      </p>
      <h1 class="page-title">{entry.data.title}</h1>
      <p class="desc">{entry.data.description}</p>
      {
        entry.data.draft && (
          <p class="draft-banner" role="note">
            <span class="pill">draft</span>
            This page is awaiting owner review. Content may change.
          </p>
        )
      }
    </header>
    <div class="prose">
      <Content />
    </div>
  </article>
</DocsLayout>

<style>
  .doc header {
    margin-bottom: 2.5rem;
  }

  .crumb {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--text-muted);
    display: inline-flex;
    gap: 0.5rem;
    margin: 0 0 1rem;
  }

  .crumb a {
    color: var(--text-secondary);
    text-decoration: none;
  }

  .crumb a:hover {
    color: var(--accent);
  }

  h1 {
    font-size: var(--fs-3xl);
    color: var(--text-primary);
    margin: 0 0 0.75rem;
  }

  .desc {
    color: var(--text-secondary);
    font-size: var(--fs-lg);
    line-height: var(--lh-relaxed);
    margin: 0;
  }

  .draft-banner {
    margin-top: 1.25rem;
    padding: 0.75rem 1rem;
    background: var(--accent-soft);
    border: 1px solid var(--border-accent);
    border-radius: var(--radius-md);
    color: var(--text-primary);
    font-size: var(--fs-sm);
    display: flex;
    align-items: center;
    gap: 0.625rem;
  }

  .pill {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    padding: 0.0625rem 0.4rem;
    border-radius: var(--radius-pill);
    background: var(--accent);
    color: var(--text-inverse);
    font-weight: 500;
  }
</style>

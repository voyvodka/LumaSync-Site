---
// Pagefind-powered search. Index is built by the postbuild step
// (`pagefind --site dist`); the JS runtime is loaded on demand the
// first time the modal opens — keeps the default page JS budget near
// zero for non-searching visitors.
//
// Trigger buttons: any element with [data-search-open] anywhere on the
// page opens the dialog. Global ⌘K / Ctrl+K shortcut also opens it.
---

<dialog class="search-modal" id="search-dialog" aria-label="Search">
  <form class="search-form" method="dialog">
    <div class="search-header">
      <svg viewBox="0 0 16 16" width="16" height="16" aria-hidden="true" class="search-icon">
        <path
          d="M11 7a4 4 0 1 1-8 0 4 4 0 0 1 8 0Zm-.7 3.3a5.5 5.5 0 1 1 1-1l2.7 2.7-1 1-2.7-2.7Z"
          fill="currentColor"></path>
      </svg>
      <input
        type="search"
        placeholder="Search docs, compare pages, changelog…"
        autocomplete="off"
        spellcheck="false"
        data-search-input
        aria-label="Search query"
      />
      <button type="submit" class="close" aria-label="Close">
        <kbd>Esc</kbd>
      </button>
    </div>
    <div class="search-results" data-search-results aria-live="polite">
      <p class="search-hint">
        Type to search. <kbd>↑</kbd><kbd>↓</kbd> to navigate, <kbd>↵</kbd> to open.
      </p>
    </div>
  </form>
</dialog>

<script is:inline>
  (() => {
    const dialog = document.getElementById('search-dialog');
    if (!dialog) return;
    const input = dialog.querySelector('[data-search-input]');
    const resultsEl = dialog.querySelector('[data-search-results]');
    if (!input || !resultsEl) return;

    let pagefind = null;
    let activeIndex = -1;
    let entries = [];

    const loadPagefind = async () => {
      if (pagefind) return pagefind;
      try {
        pagefind = await import(/* @vite-ignore */ '/pagefind/pagefind.js');
        await pagefind.options({ baseUrl: '/' });
        return pagefind;
      } catch (err) {
        console.warn('[search] pagefind unavailable:', err);
        return null;
      }
    };

    const openDialog = () => {
      if (!dialog.open) {
        dialog.showModal();
        requestAnimationFrame(() => input.focus());
        loadPagefind();
      }
    };

    const closeDialog = () => dialog.close();

    document.addEventListener('keydown', (e) => {
      if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === 'k') {
        e.preventDefault();
        if (dialog.open) closeDialog();
        else openDialog();
      }
    });

    document
      .querySelectorAll('[data-search-open]')
      .forEach((btn) => btn.addEventListener('click', openDialog));

    dialog.addEventListener('click', (e) => {
      if (e.target === dialog) closeDialog();
    });

    const renderEmpty = () => {
      resultsEl.innerHTML =
        '<p class="search-hint">Type to search. <kbd>↑</kbd><kbd>↓</kbd> to navigate, <kbd>↵</kbd> to open.</p>';
      entries = [];
      activeIndex = -1;
    };

    const renderResults = (hits) => {
      if (hits.length === 0) {
        resultsEl.innerHTML =
          '<p class="search-empty">No matches. Try a different phrase.</p>';
        entries = [];
        activeIndex = -1;
        return;
      }
      resultsEl.innerHTML = hits
        .map(
          (r, i) => `
            <a class="search-result" href="${r.url}" data-index="${i}">
              <span class="result-kicker">${escapeHtml(r.meta?.section || r.meta?.category || '')}</span>
              <span class="result-title">${escapeHtml(r.meta?.title || r.url)}</span>
              <span class="result-excerpt">${r.excerpt || ''}</span>
            </a>`,
        )
        .join('');
      entries = Array.from(resultsEl.querySelectorAll('.search-result'));
      setActive(0);
    };

    const setActive = (idx) => {
      activeIndex = idx;
      entries.forEach((el, i) => el.toggleAttribute('data-active', i === idx));
      if (entries[idx]) entries[idx].scrollIntoView({ block: 'nearest' });
    };

    const escapeHtml = (s) =>
      String(s)
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;');

    let queryTimer = 0;
    input.addEventListener('input', (e) => {
      clearTimeout(queryTimer);
      const q = e.target.value.trim();
      if (!q) {
        renderEmpty();
        return;
      }
      queryTimer = window.setTimeout(async () => {
        const pf = await loadPagefind();
        if (!pf) {
          resultsEl.innerHTML =
            '<p class="search-empty">Search index not available. Run a full build first.</p>';
          return;
        }
        const { results } = await pf.search(q);
        const data = await Promise.all(results.slice(0, 8).map((r) => r.data()));
        renderResults(data);
      }, 120);
    });

    dialog.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowDown') {
        e.preventDefault();
        if (entries.length) setActive(Math.min(activeIndex + 1, entries.length - 1));
      } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        if (entries.length) setActive(Math.max(activeIndex - 1, 0));
      } else if (e.key === 'Enter' && activeIndex >= 0 && entries[activeIndex]) {
        e.preventDefault();
        entries[activeIndex].click();
      }
    });
  })();
</script>

<style>
  .search-modal {
    background: transparent;
    border: none;
    padding: 0;
    max-width: none;
    max-height: none;
    width: 100%;
    height: 100%;
    color: var(--text-primary);
  }

  .search-modal::backdrop {
    background: rgba(5, 6, 9, 0.72);
    backdrop-filter: blur(4px);
  }

  .search-form {
    max-width: 36rem;
    margin: 6rem auto 0;
    background: var(--surface-1);
    border: 1px solid var(--border-strong);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-lift);
    overflow: hidden;
    display: grid;
    grid-template-rows: auto 1fr;
    max-height: calc(100dvh - 8rem);
  }

  .search-header {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.875rem 1rem;
    border-bottom: 1px solid var(--border);
  }

  .search-icon {
    color: var(--text-muted);
    flex-shrink: 0;
  }

  .search-header input {
    flex: 1;
    background: none;
    border: none;
    outline: none;
    color: var(--text-primary);
    font-size: var(--fs-md);
    font-family: var(--font-sans);
    padding: 0.125rem 0;
  }

  .search-header input::placeholder {
    color: var(--text-muted);
  }

  .close {
    background: none;
    border: none;
    padding: 0.25rem 0.5rem;
    cursor: pointer;
  }

  .close kbd {
    font-size: 0.7rem;
  }

  .search-results {
    overflow-y: auto;
    padding: 0.5rem;
  }

  .search-hint,
  .search-empty {
    margin: 0;
    padding: 1rem 0.75rem;
    color: var(--text-muted);
    font-size: var(--fs-sm);
  }

  .search-hint kbd {
    margin-inline: 0.0625rem;
    font-size: 0.7rem;
  }

  .search-result {
    display: grid;
    gap: 0.2rem;
    padding: 0.625rem 0.75rem;
    border-radius: var(--radius-md);
    text-decoration: none;
    color: var(--text-primary);
    transition: background-color var(--duration-fast) var(--ease-out);
  }

  .search-result:hover,
  .search-result[data-active] {
    background: var(--surface-2);
  }

  .search-result[data-active] {
    box-shadow: inset 2px 0 0 var(--accent);
  }

  .result-kicker {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--accent);
  }

  .result-kicker:empty {
    display: none;
  }

  .result-title {
    font-weight: 500;
    color: var(--text-primary);
  }

  .result-excerpt {
    color: var(--text-secondary);
    font-size: var(--fs-sm);
    line-height: var(--lh-relaxed);
  }

  .result-excerpt :global(mark) {
    background: var(--accent-soft);
    color: var(--accent);
    padding: 0 0.125rem;
    border-radius: var(--radius-sm);
  }

  @media (max-width: 640px) {
    .search-form {
      margin-top: 2rem;
      max-height: calc(100dvh - 4rem);
    }
  }
</style>

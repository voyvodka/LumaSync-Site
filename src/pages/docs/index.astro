---
import DocsLayout from '../../layouts/DocsLayout.astro';
import { groupDocs, docHref } from '../../lib/content';
import { breadcrumbSchema } from '../../lib/seo';

const groups = await groupDocs();
const totalCount = groups.reduce((sum, g) => sum + g.items.length, 0);

const schemas = [
  breadcrumbSchema([
    { name: 'Home', url: '/' },
    { name: 'Docs', url: '/docs' },
  ]),
];
---

<DocsLayout
  title="Docs"
  description="LumaSync documentation — setup, hardware, Philips Hue, troubleshooting, reference."
  schemas={schemas}
>
  <section class="docs-index">
    <header>
      <p class="eyebrow">Documentation</p>
      <h1 class="page-title">LumaSync Docs</h1>
      <p class="lede">
        Everything needed to go from fresh install to a calibrated ambilight setup. Start with <a
          href="/docs/getting-started/install">Install</a
        >, then work through the group that matches your hardware.
      </p>
    </header>

    {
      totalCount === 0 && (
        <p class="empty">
          No docs published yet. The Phase 1 MVP ships in Week 2 per the action plan.
        </p>
      )
    }

    {
      groups.map(({ label, items }) => (
        <section class="group">
          <h2>{label}</h2>
          <ul role="list">
            {items.map((item) => (
              <li>
                <a href={docHref(item)}>
                  <span class="title-row">
                    <span class="title">{item.data.title}</span>
                    {item.data.draft && <span class="pill">draft</span>}
                  </span>
                  <span class="desc">{item.data.description}</span>
                </a>
              </li>
            ))}
          </ul>
        </section>
      ))
    }
  </section>
</DocsLayout>

<style>
  .docs-index > header {
    margin-bottom: 2.5rem;
  }

  h1 {
    font-size: var(--fs-3xl);
    margin: 0 0 0.75rem;
  }

  .lede {
    color: var(--text-secondary);
    font-size: var(--fs-lg);
    line-height: var(--lh-relaxed);
    margin: 0;
    max-width: 36rem;
  }

  .lede a {
    color: var(--text-primary);
    text-decoration: underline;
    text-decoration-color: var(--border-strong);
    text-underline-offset: 3px;
  }

  .lede a:hover {
    text-decoration-color: var(--accent);
  }

  .group {
    margin-top: 2.5rem;
  }

  .group h2 {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--text-muted);
    margin: 0 0 0.75rem;
    font-weight: 500;
  }

  ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.5rem;
  }

  li a {
    display: block;
    padding: 1rem 1.125rem;
    background: var(--surface-1);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    text-decoration: none;
    transition:
      border-color var(--duration-fast) var(--ease-out),
      background-color var(--duration-fast) var(--ease-out);
  }

  li a:hover {
    border-color: var(--border-strong);
    background: var(--surface-2);
  }

  .title-row {
    display: flex;
    align-items: center;
    gap: 0.625rem;
  }

  .title {
    color: var(--text-primary);
    font-weight: 500;
  }

  .pill {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    padding: 0.0625rem 0.4rem;
    border-radius: var(--radius-pill);
    background: var(--accent-soft);
    color: var(--accent);
  }

  .desc {
    display: block;
    color: var(--text-secondary);
    font-size: var(--fs-sm);
    margin-top: 0.25rem;
  }

  .empty {
    color: var(--text-muted);
  }
</style>
